rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#
cmtdenormalized-100:	http://cmt#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping-551974709
target		<http://example.com/rejection/{ID}> a cmtdenormalized-100:Rejection . 
source		SELECT "ID" FROM "Rejection"

mappingId	mapping-1589238687
target		<http://example.com/conference/{Conference}> cmtdenormalized-100:reviewCriteriaEnteredBy <http://example.com/person/{Administrator}> . 
source		SELECT "Conference" , "Administrator" FROM "enterReviewCriteria"

mappingId	mapping-615443105
target		<http://example.com/document/{ID}> a cmtdenormalized-100:Paper ; cmtdenormalized-100:hasAuthor <http://example.com/person/{hasAuthor}> ; cmtdenormalized-100:rejectedBy <http://example.com/person/{rejectedBy}> ; cmtdenormalized-100:title {title}^^xsd:string ; cmtdenormalized-100:paperid {paperID}^^xsd:unsignedLong ; cmtdenormalized-100:paperID {paperID}^^xsd:unsignedLong ; cmtdenormalized-100:readByMeta-Reviewer <http://example.com/person/{readByMeta-Reviewer}> ; cmtdenormalized-100:hasDecision <http://example.com/rejection/{hasDecision}> ; cmtdenormalized-100:acceptedBy <http://example.com/person/{acceptedBy}> . 
source		SELECT "ID" , "paperID" , "rejectedBy" , "readByMeta-Reviewer" , "hasAuthor" , "title" , "hasDecision" , "acceptedBy" , "TYPE" , "Reviewer" FROM "Paper"

mappingId	mapping--1212810048
