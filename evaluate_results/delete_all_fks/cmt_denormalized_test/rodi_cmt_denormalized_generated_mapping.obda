target		<http://example.com/conference/{ID}> a cmtdenormalized-100:Conference ; cmtdenormalized-100:date {date}^^xsd:date ; cmtdenormalized-100:name {name}^^xsd:string ; cmtdenormalized-100:reviewsPerPaper {reviewsPerPaper}^^xsd:int ; cmtdenormalized-100:siteURL {siteURL}^^xsd:anyURI ; cmtdenormalized-100:reviewsperpaper {reviewsPerPaper}^^xsd:int ; cmtdenormalized-100:siteurl {siteURL}^^xsd:anyURI ; cmtdenormalized-100:logoURL {logoURL}^^xsd:anyURI ; cmtdenormalized-100:logourl {logoURL}^^xsd:anyURI . 
