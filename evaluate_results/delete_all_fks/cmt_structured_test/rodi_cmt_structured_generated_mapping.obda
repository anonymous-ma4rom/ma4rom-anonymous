mappingId	mapping-540301488
target		<http://example.com/person/{ID}> a cmtstructured-100:ProgramCommitteeMember ; cmtstructured-100:maxPapers {maxPapers}^^xsd:int ; cmtstructured-100:addedBy <http://example.com/administrator/{addedBy}> . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeMember"

mappingId	mapping--457722661
target		<http://example.com/review/{ID}> a cmtstructured-100:Review ; cmtstructured-100:writtenBy <http://example.com/person/{writtenBy}> ; rdfs:comment {comment}^^xsd:string . 
source		SELECT "ID" , "writtenBy" , "comment" , "TYPE" FROM "Review"

mappingId	mapping--1071717441
target		<http://example.com/document/{Paper}> cmtstructured-100:assignedTo <http://example.com/person/{Reviewer}> . 
