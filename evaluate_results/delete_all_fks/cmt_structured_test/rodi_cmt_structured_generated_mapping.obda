mappingId	mapping--1032359805
target		<http://example.com/conference/{ID}> a cmtstructured-100:Conference ; cmtstructured-100:reviewsPerPaper {reviewsPerPaper}^^xsd:int ; cmtstructured-100:siteURL {siteURL}^^xsd:anyURI ; cmtstructured-100:name {name}^^xsd:string ; cmtstructured-100:date {date}^^xsd:date ; cmtstructured-100:logourl {logoURL}^^xsd:anyURI ; cmtstructured-100:logoURL {logoURL}^^xsd:anyURI ; cmtstructured-100:siteurl {siteURL}^^xsd:anyURI . 
