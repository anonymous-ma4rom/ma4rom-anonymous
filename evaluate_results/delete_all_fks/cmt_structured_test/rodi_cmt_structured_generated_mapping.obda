mappingId	mapping-984649234
target		<http://example.com/document/{ID}> a cmtstructured-100:PaperFullVersion . 
source		SELECT "ID" FROM "Paper" WHERE "TYPE" = 1

mappingId	mapping-1154999653
target		<http://example.com/document/{ID}> a cmtstructured-100:PaperAbstract . 
