[PrefixDeclaration]
rr:		http://www.w3.org/ns/r2rml#
rdf:		http://www.w3.org/1999/02/22-rdf-syntax-ns#
rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#
cmtstructured-100:	http://cmt#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping-1339377769
target		<http://example.com/acceptance/{ID}> a cmtstructured-100:Acceptance . 
source		SELECT "ID" , "TYPE" FROM "Acceptance"

mappingId	mapping-1768635337
target		<http://example.com/administrator/{Administrator}> cmtstructured-100:enterReviewCriteria <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "enterReviewCriteria"

mappingId	mapping-518856271
target		<http://example.com/document/{ID}> cmtstructured-100:acceptedBy <http://example.com/administrator/{acceptedBy}> ; cmtstructured-100:paperid {readByMeta-Reviewer}^^xsd:unsignedLong , {paperID}^^xsd:unsignedLong , {hasDecision}^^xsd:unsignedLong ; cmtstructured-100:paperID {paperID}^^xsd:unsignedLong , {readByMeta-Reviewer}^^xsd:unsignedLong , {hasDecision}^^xsd:unsignedLong ; cmtstructured-100:rejectedBy <http://example.com/administrator/{rejectedBy}> ; cmtstructured-100:hasAuthor <http://example.com/person/{hasAuthor}> ; cmtstructured-100:title {title}^^xsd:string . 
source		SELECT "ID" , "paperID" , "rejectedBy" , "readByMeta-Reviewer" , "hasAuthor" , "title" , "hasDecision" , "acceptedBy" , "TYPE" FROM "Paper"

mappingId	mapping-1416609150
target		<http://example.com/document/{Paper}> cmtstructured-100:submitPaper <http://example.com/person/{Author}> . 
source		SELECT "Paper" , "Author" FROM "submitPaper"

mappingId	mapping--668994338
target		<http://example.com/person/{ID}> a cmtstructured-100:Person ; cmtstructured-100:email {assignedByReviewer}^^xsd:string , {email}^^xsd:string ; cmtstructured-100:name {name}^^xsd:string . 
source		SELECT "ID" , "name" , "email" , "is_user" , "assignedByReviewer" , "is_Reviewer" , "is_Author" , "is_Co-author" , "TYPE" FROM "Person"

mappingId	mapping-960524003
target		<http://example.com/conference/{Conference}> cmtstructured-100:hasConferenceMember <http://example.com/person/{ConferenceMember}> . 
source		SELECT "Conference" , "ConferenceMember" FROM "hasConferenceMember"

mappingId	mapping--2051231441
target		<http://example.com/document/{Paper}> cmtstructured-100:readByReviewer <http://example.com/person/{Reviewer}> . 
source		SELECT "Paper" , "Reviewer" FROM "readByReviewer"

mappingId	mapping--1341637669
target		<http://example.com/subjectarea/{ID}> a cmtstructured-100:SubjectArea . 
source		SELECT "ID" FROM "SubjectArea"

mappingId	mapping--1980589072
target		<http://example.com/person/{ID}> a cmtstructured-100:Author . 
source		SELECT "ID" FROM "Person" WHERE "is_Author" = true

mappingId	mapping-529146330
target		<http://example.com/administrator/{ID}> a cmtstructured-100:Administrator ; cmtstructured-100:acceptPaper <http://example.com/acceptance/{acceptPaper}> . 
source		SELECT "ID" , "acceptPaper" FROM "Administrator"

mappingId	mapping--1837084365
target		<http://example.com/person/{ProgramCommitteeChair}> cmtstructured-100:endReview <http://example.com/review/{Review}> . 
source		SELECT "ProgramCommitteeChair" , "Review" FROM "endReview"

mappingId	mapping-1298756227
target		<http://example.com/bid/{ID}> a cmtstructured-100:Bid ; cmtstructured-100:hasBid <http://example.com/document/{hasBid_Inv}> ; cmtstructured-100:adjustedBy <http://example.com/person/{adjustedBy}> . 
source		SELECT "ID" , "adjustedBy" , "hasBid_Inv" FROM "Bid"

mappingId	mapping-379302202
target		<http://example.com/programcommittee/{ID}> a cmtstructured-100:ProgramCommittee ; rdfs:label {label}^^xsd:string ; cmtstructured-100:name {label}^^xsd:string . 
source		SELECT "ID" , "label" FROM "ProgramCommittee"

