target		<http://example.com/person/{ID}> a cmtstructured-100:User . 
source		SELECT "ID" FROM "Person" WHERE "is_user" = true

mappingId	mapping--1934766402
target		<http://example.com/review/{ID}> a cmtstructured-100:Review . 
