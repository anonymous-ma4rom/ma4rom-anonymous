mappingId	mapping-593267936
target		<http://example.com/person/{ID}> a cmtstructured-100:ProgramCommitteeChair ; cmtstructured-100:maxPapers {maxPapers}^^xsd:int ; cmtstructured-100:addedBy <http://example.com/administrator/{addedBy}> . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeChair"

