    rr:subjectMap [ rr:template "http://example.com/bid/{ID}" ; rr:class cmtstructured-100:Bid ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:adjustedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{adjustedBy}" ]
    ] ;
