@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtstructured-100: <http://cmt#> .
@base <http://example.com/> .

# === Paper (SH) ===
<#PaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"paperID\" , \"rejectedBy\" , \"readByMeta-Reviewer\" , \"hasAuthor\" , \"title\" , \"hasDecision\" , \"acceptedBy\" , \"TYPE\" FROM \"Paper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:paperID ;
        rr:objectMap [ rr:column "paperID" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:paperid ;
        rr:objectMap [ rr:column "paperID" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:rejectedBy ;
        rr:objectMap [ rr:template "http://example.com/administrator/{rejectedBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:paperID ;
        rr:objectMap [ rr:column "readByMeta-Reviewer" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:paperid ;
        rr:objectMap [ rr:column "readByMeta-Reviewer" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:hasAuthor ;
        rr:objectMap [ rr:template "http://example.com/person/{hasAuthor}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:title ;
        rr:objectMap [ rr:column "title" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:paperID ;
        rr:objectMap [ rr:column "hasDecision" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:paperid ;
        rr:objectMap [ rr:column "hasDecision" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:acceptedBy ;
        rr:objectMap [ rr:template "http://example.com/administrator/{acceptedBy}" ]
    ] .

# === ProgramCommitteeChair (SH) ===
<#ProgramCommitteeChairMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"maxPapers\" , \"addedBy\" FROM \"ProgramCommitteeChair\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtstructured-100:ProgramCommitteeChair ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:maxPapers ;
        rr:objectMap [ rr:column "maxPapers" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:addedBy ;
        rr:objectMap [ rr:template "http://example.com/administrator/{addedBy}" ]
    ] .

# === ProgramCommitteeMember (SH) ===
<#ProgramCommitteeMemberMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"maxPapers\" , \"addedBy\" FROM \"ProgramCommitteeMember\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtstructured-100:ProgramCommitteeMember ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:maxPapers ;
        rr:objectMap [ rr:column "maxPapers" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured-100:addedBy ;
        rr:objectMap [ rr:template "http://example.com/administrator/{addedBy}" ]
    ] .

