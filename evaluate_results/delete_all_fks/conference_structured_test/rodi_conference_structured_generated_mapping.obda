mappingId	mapping-1372975549
target		<http://example.com/important_dates/{ID}> a conferencestructured-100:Important_dates ; conferencestructured-100:is_an_ending_date {is_an_ending_date}^^xsd:date ; conferencestructured-100:is_a_date_of_camera_ready_paper_submission {is_a_date_of_camera_ready}^^xsd:date ; conferencestructured-100:is_a_full_paper_submission_date {is_a_full_paper_submissio}^^xsd:date ; conferencestructured-100:is_an_abstract_submission_date {is_an_abstract_submission}^^xsd:date ; conferencestructured-100:is_a_date_of_acceptance_announcement {is_a_date_of_acceptance_a}^^xsd:date ; conferencestructured-100:is_a_starting_date {is_a_starting_date}^^xsd:date . 
