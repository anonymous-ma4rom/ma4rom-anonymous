mappingId	mapping-453762513
target		<http://example.com/document/{ID}> a sigkddstructured-100:Review . 
source		SELECT "ID" FROM "Document" WHERE "TYPE" = 3

mappingId	mapping--1642540840
target		<http://example.com/main_office/{ID}> a sigkddstructured-100:Main_office ; sigkddstructured-100:hasPostalCode {hasPostalCode}^^xsd:int ; sigkddstructured-100:hasStreet {hasStreet}^^xsd:string ; <http://www.w3.org/2003/01/geo/wgs84_pos#long> {long}^^xsd:float ; <http://www.w3.org/2003/01/geo/wgs84_pos#lat> {lat}^^xsd:float . 
source		SELECT "ID" , "lat" , "long" , "hasStreet" , "hasPostalCode" , "TYPE" FROM "Main_office"

mappingId	mapping-1028488802
target		<http://example.com/document/{ID}> a sigkddstructured-100:Abstract . 
source		SELECT "ID" FROM "Document" WHERE "TYPE" = 2

