mappingId	mapping-829233972
target		<http://example.com/document/{ID}> a sigkddstructured-100:Review ; sigkddstructured-100:hasid {hasID}^^xsd:int ; sigkddstructured-100:isReviewOf <http://example.com/document/{hasReview_Inv}> , <http://example.com/document/{isReviewOf}> ; sigkddstructured-100:hasID {hasID}^^xsd:int ; sigkddstructured-100:hasText {hasText}^^xsd:string . 
