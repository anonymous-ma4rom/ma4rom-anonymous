mappingId	mapping--1909610961
target		<http://example.com/person/{ID}> a sigkddstructured-100:Person ; sigkddstructured-100:Name {Name}^^xsd:string ; sigkddstructured-100:Name_of_sponsor {Name_of_sponsor}^^xsd:string ; sigkddstructured-100:Nation {Nation}^^xsd:string . 
source		SELECT "ID" , "Nation" , "Name" , "Name_of_sponsor" , "is_Organizator" , "is_Program_Chair" , "is_Listener" , "is_Author_of_paper_student" , "is_Program_Committee_member" , "TYPE" FROM "Person"

mappingId	mapping-1424443650
target		<http://example.com/person/{Author}> sigkddstructured-100:obtain <http://example.com/best_paper_awards_committ/{Award}> . 
