rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#
sigkddstructured-100:	http://sigkdd#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping--1516985445
target		<http://example.com/acm_sigkdd/{ACM_SIGKDD}> sigkddstructured-100:search <http://example.com/person/{Sponzor}> . 
source		SELECT "ACM_SIGKDD" , "Sponzor" FROM "search"

mappingId	mapping-1870212939
target		<http://example.com/deadline_abstract_submiss/{ID}> a sigkddstructured-100:Deadline_Abstract_Submission ; sigkddstructured-100:Date {Date}^^xsd:dateTime . 
source		SELECT "ID" , "designed_by" , "Date" , "TYPE" FROM "Deadline_Abstract_Submiss"

mappingId	mapping-181111025
target		<http://example.com/person/{ID}> a sigkddstructured-100:Program_Committee_member . 
source		SELECT "ID" FROM "Person" WHERE "is_Program_Committee_member" = true

mappingId	mapping-1553375936
target		<http://example.com/person/{Person}> sigkddstructured-100:can_stay_in <http://example.com/main_office/{Place}> . 
source		SELECT "Person" , "Place" FROM "can_stay_in"

mappingId	mapping-43560088
target		<http://example.com/registration_fee/{ID}> a sigkddstructured-100:Registration_fee ; sigkddstructured-100:Price {Price}^^xsd:int ; sigkddstructured-100:Currency {Currency}^^xsd:string . 
source		SELECT "ID" , "Currency" , "Price" , "TYPE" FROM "Registration_fee"

mappingId	mapping-500631137
target		<http://example.com/person/{Person}> sigkddstructured-100:E-mail {VALUE}^^xsd:string . 
