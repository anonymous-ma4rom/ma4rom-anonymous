target		<http://example.com/bsns_arr_area_licensee_hst/{baanpdidbsnsarrarea}__{cmpnpdidcompany}__{baalicenseedatevalidfrom}__{baalicenseedatevalidto}> a <http://www.ifomis.org/bfo/1.1/span#ScatteredTemporalRegion> ; <http://sws.ifi.uio.no/vocab/npd-v2#name> {baaname}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#DSTGasProducedRate> {baanpdidbsnsarrarea}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#licenseeInterest> {baalicenseeinterest}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#LOTMudDensity> {cmpnpdidcompany}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#dateLicenceAreaValidFrom> {baalicenseedatevalidfrom}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#dateLicenceAreaValidTo> {baalicenseedatevalidto}^^xsd:dateTime , {baalicenseedateupdated}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> {datesyncnpd}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#datesyncnpd> {datesyncnpd}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#casingDiameter> {baalicenseesdfi}^^xsd:string . 
