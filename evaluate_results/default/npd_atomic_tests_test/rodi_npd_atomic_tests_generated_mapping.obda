mappingId	mapping-2083397676
target		<http://sws.ifi.uio.no/data/npd-v2/wellbore_npdid_overview/{wlbnpdidwellbore}> a <http://sws.ifi.uio.no/vocab/npd-v2#WellboreCoordinate> ; <http://sws.ifi.uio.no/vocab/npd-v2#secondsEW> {wlbewsec}^^xsd:decimal , {wlbnssec}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#utmEW> {wlbewutm}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#wellboreContent> {wlbcontent}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#codeEW> {wlbewcode}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#degreesNS> {wlbnsdeg}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#utmZone> {wlbutmzone}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#dateWellboreEntry> {wlbentrydate}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#decimalDegreesEW> {wlbnsdecdeg}^^xsd:decimal , {wlbewdesdeg}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#wellborePlannedPurpose> {wlbpurposeplanned}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#minutesNS> {wlbnsmin}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> {datesyncnpd}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#dateOilSampleTest> {wlbcompletiondate}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#wellboreParent> {wlbwellborename}^^xsd:string ; <http://www.w3.org/2004/02/skos/core#prefLabel> {wlbfield}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#utmNS> {wlbnsutm}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#degreesEW> {wlbewdeg}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#geodeticDatum> {wlbgeodeticdatum}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#minutesEW> {wlbewmin}^^xsd:integer . 
