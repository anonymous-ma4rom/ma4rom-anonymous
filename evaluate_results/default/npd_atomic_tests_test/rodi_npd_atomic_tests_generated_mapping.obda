mappingId	mapping--1681888122
target		<http://sws.ifi.uio.no/data/npd-v2/field_owner_hst/{fldnpdidfield}__{fldnpdidowner}__{fldownershipfromdate}__{fldownershiptodate}> a <http://sws.ifi.uio.no/vocab/npd-v2#FieldOwner> ; <http://sws.ifi.uio.no/vocab/npd-v2#dateFieldOwnerTo> {fldownerdateupdated}^^xsd:dateTime , {fldownershiptodate}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> {datesyncnpd}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#dateFieldOwnerFrom> {fldownershipfromdate}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#ownerForField> <http://sws.ifi.uio.no/data/npd-v2/field/{fldnpdidfield}> ; <http://sws.ifi.uio.no/vocab/npd-v2#name> {fldname}^^xsd:string . 
