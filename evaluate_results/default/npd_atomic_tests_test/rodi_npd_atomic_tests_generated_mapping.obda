mappingId	mapping-174009455
target		<http://sws.ifi.uio.no/data/npd-v2/facility_fixed/{fclnpdidfacility}> a <http://sws.ifi.uio.no/vocab/npd-v2#FixedFacility> ; <http://sws.ifi.uio.no/vocab/npd-v2#designLifetime> {fclnssec}^^xsd:integer , {fclbelongstos}^^xsd:integer , {fclewdeg}^^xsd:integer , {fclewmin}^^xsd:integer , {fcldesignlifetime}^^xsd:integer , {fclnsdeg}^^xsd:integer , {fclnsmin}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#codeEW> {fclewcode}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#codeNS> {fclnscode}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#waterDepth> {fclwaterdepth}^^xsd:decimal , {fclewsec}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#facilityFunction> {fclfunctions}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#dateProductionStart> {fclstartupdate}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#geodeticDatum> {fclgeodeticdatum}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> {datesyncnpd}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#dateUpdated> {fcldateupdated}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#name> {fclname}^^xsd:string . 
source		SELECT "fclname" , "fclphase" , "fclsurface" , "fclcurrentoperatorname" , "fclkind" , "fclbelongstoname" , "fclbelongstokind" , "fclbelongstos" , "fclstartupdate" , "fclgeodeticdatum" , "fclnsdeg" , "fclnsmin" , "fclnssec" , "fclnscode" , "fclewdeg" , "fclewmin" , "fclewsec" , "fclewcode" , "fclwaterdepth" , "fclfunctions" , "fcldesignlifetime" , "fclfactpageurl" , "fclfactmapurl" , "fclnpdidfacility" , "fcldateupdated" , "datesyncnpd" FROM "facility_fixed"

mappingId	mapping--657313291
target		<http://sws.ifi.uio.no/data/npd-v2/facility_fixed/{fclnpdidfacility}> <http://sws.ifi.uio.no/vocab/npd-v2#facilityFunction> {fclfunctions}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#coresTotalLength> {fclbelongstos}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#designLifetime> {fcldesignlifetime}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#name> {fclname}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#waterDepth> {fclwaterdepth}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#dateStatusFrom> {fclstartupdate}^^xsd:dateTime . 
