    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"is_part_of_conference_vol\" , \"has_a_name\" FROM \"Conference_part\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_part/{ID}" ; rr:class conferencenaive:Conference_part ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:is_part_of_conference_volumes ;
        rr:objectMap [ rr:template "http://example.com/conference/{is_part_of_conference_vol}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:has_a_name ;
        rr:objectMap [ rr:column "has_a_name" ; rr:datatype xsd:string ]
    ] .

