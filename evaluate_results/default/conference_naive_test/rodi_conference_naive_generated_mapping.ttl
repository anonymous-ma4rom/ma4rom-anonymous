# === Conference_volume (SH) ===
<#Conference_volumeMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"has_a_program_committee\" , \"has_an_organizing_committ\" , \"has_a_location\" , \"has_a_steering_committee\" , \"has_important_dates\" FROM \"Conference_volume\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{ID}" ; rr:class conferencenaive:Conference_volume ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:has_a_program_committee ;
        rr:objectMap [ rr:template "http://example.com/committee/{has_a_program_committee}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:has_an_organizing_committee ;
        rr:objectMap [ rr:template "http://example.com/committee/{has_an_organizing_committ}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:has_a_location ;
        rr:objectMap [ rr:column "has_a_location" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:has_a_steering_committee ;
        rr:objectMap [ rr:template "http://example.com/committee/{has_a_steering_committee}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:has_important_dates ;
        rr:objectMap [ rr:template "http://example.com/important_dates/{has_important_dates}" ]
    ] .

