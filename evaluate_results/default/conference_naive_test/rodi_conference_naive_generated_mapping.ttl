@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix conferencenaive: <http://conference#> .
@base <http://example.com/> .

# === Abstract (SH) ===
<#AbstractMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"is_the_1th_part_of\" FROM \"Abstract\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ; rr:class conferencenaive:Abstract ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:is_the_1th_part_of ;
        rr:objectMap [ rr:template "http://example.com/conference_document/{is_the_1th_part_of}" ]
    ] .

