# === Conference_fees (SE) ===
<#Conference_feesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"amount\" FROM \"Conference_fees\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_fees/{ID}" ; rr:class conferencenaive:Conference_fees ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenaive:amount ;
        rr:objectMap [ rr:column "amount" ; rr:datatype xsd:string ]
    ] .

