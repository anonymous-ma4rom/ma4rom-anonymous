[PrefixDeclaration]
rr:		http://www.w3.org/ns/r2rml#
rdf:		http://www.w3.org/1999/02/22-rdf-syntax-ns#
rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#
cmtstructured:	http://cmt#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping--1947758610
target		<http://example.com/acceptance/{ID}> a cmtstructured:Acceptance . 
source		SELECT "ID" , "TYPE" FROM "Acceptance"

mappingId	mapping--1266345002
target		<http://example.com/person/{Administrator}> cmtstructured:enterReviewCriteria <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "enterReviewCriteria"

mappingId	mapping-970075338
target		<http://example.com/document/{ID}> cmtstructured:acceptedBy <http://example.com/person/{acceptedBy}> ; cmtstructured:paperID {paperID}^^xsd:unsignedLong ; cmtstructured:readByMeta-Reviewer <http://example.com/person/{readByMeta-Reviewer}> ; cmtstructured:paperid {paperID}^^xsd:unsignedLong ; cmtstructured:rejectedBy <http://example.com/person/{rejectedBy}> ; cmtstructured:title {title}^^xsd:string ; cmtstructured:hasAuthor <http://example.com/person/{hasAuthor}> ; cmtstructured:hasDecision <http://example.com/acceptance/{hasDecision}> . 
source		SELECT "ID" , "paperID" , "rejectedBy" , "readByMeta-Reviewer" , "hasAuthor" , "title" , "hasDecision" , "acceptedBy" , "TYPE" FROM "Paper"

mappingId	mapping-275748596
target		<http://example.com/person/{ID}> a cmtstructured:Person ; cmtstructured:assignedByReviewer <http://example.com/person/{assignedByReviewer}> ; cmtstructured:email {email}^^xsd:string ; cmtstructured:name {name}^^xsd:string . 
source		SELECT "ID" , "name" , "email" , "is_user" , "assignedByReviewer" , "is_Reviewer" , "is_Author" , "is_Co-author" , "TYPE" FROM "Person"

mappingId	mapping--1105762051
target		<http://example.com/document/{Paper}> cmtstructured:readByReviewer <http://example.com/person/{Reviewer}> . 
source		SELECT "Paper" , "Reviewer" FROM "readByReviewer"

mappingId	mapping--1389089504
target		<http://example.com/conference/{Conference}> cmtstructured:hasConferenceMember <http://example.com/person/{ConferenceMember}> . 
source		SELECT "Conference" , "ConferenceMember" FROM "hasConferenceMember"

mappingId	mapping--9250905
target		<http://example.com/person/{ID}> a cmtstructured:Author . 
source		SELECT "ID" FROM "Person" WHERE "is_Author" = true

mappingId	mapping--451509617
target		<http://example.com/subjectarea/{ID}> a cmtstructured:SubjectArea . 
source		SELECT "ID" FROM "SubjectArea"

mappingId	mapping-537706689
target		<http://example.com/person/{ProgramCommitteeChair}> cmtstructured:endReview <http://example.com/document/{Review}> . 
source		SELECT "ProgramCommitteeChair" , "Review" FROM "endReview"

mappingId	mapping--870512670
target		<http://example.com/person/{ID}> a cmtstructured:Administrator ; cmtstructured:acceptPaper <http://example.com/document/{acceptPaper}> . 
source		SELECT "ID" , "acceptPaper" FROM "Administrator"

mappingId	mapping--1269531277
target		<http://example.com/programcommittee/{ID}> a cmtstructured:ProgramCommittee ; rdfs:label {label}^^xsd:string ; cmtstructured:email {label}^^xsd:string . 
source		SELECT "ID" , "label" FROM "ProgramCommittee"

mappingId	mapping--750311545
target		<http://example.com/bid/{ID}> a cmtstructured:Bid ; cmtstructured:adjustedBy <http://example.com/person/{adjustedBy}> . 
source		SELECT "ID" , "adjustedBy" , "hasBid_Inv" FROM "Bid"

mappingId	mapping--59971576
target		<http://example.com/person/{Administrator}> cmtstructured:finalizePaperAssignment <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "finalizePaperAssignment"

mappingId	mapping--546833483
target		<http://example.com/person/{ID}> a cmtstructured:Reviewer . 
source		SELECT "ID" FROM "Person" WHERE "TYPE" = 1

mappingId	mapping-1293360061
target		<http://example.com/document/{Paper}> cmtstructured:hasSubjectArea <http://example.com/subjectarea/{SubjectArea}> . 
source		SELECT "Paper" , "SubjectArea" FROM "hasSubjectArea"

mappingId	mapping-544614124
target		<http://example.com/person/{ID}> a cmtstructured:ProgramCommitteeChair ; cmtstructured:maxPapers {maxPapers}^^xsd:int ; cmtstructured:addedBy <http://example.com/person/{addedBy}> . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeChair"

mappingId	mapping-1293569129
target		<http://example.com/document/{Paper}> cmtstructured:hasCo-author <http://example.com/person/{Co-author}> . 
source		SELECT "Paper" , "Co-author" FROM "co-writePaper"

mappingId	mapping-736545762
target		<http://example.com/person/{Administrator}> cmtstructured:assignReviewer <http://example.com/person/{Reviewer}> . 
source		SELECT "Administrator" , "Reviewer" FROM "assignReviewer"

mappingId	mapping--514078239
target		<http://example.com/person/{ID}> a cmtstructured:User . 
source		SELECT "ID" FROM "Person" WHERE "is_user" = true

mappingId	mapping-483703057
target		<http://example.com/document/{ID}> a cmtstructured:Review . 
source		SELECT "ID" FROM "Review" WHERE "TYPE" = 0

mappingId	mapping-800461815
target		<http://example.com/person/{ID}> a cmtstructured:Reviewer . 
source		SELECT "ID" FROM "Person" WHERE "is_Reviewer" = true

mappingId	mapping-1154609892
target		<http://example.com/person/{Administrator}> cmtstructured:enterConferenceDetails <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "detailsEnteredBy"

mappingId	mapping-2045101670
target		<http://example.com/person/{Administrator}> cmtstructured:enableVirtualMeeting <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "enableVirtualMeeting"

mappingId	mapping--1774456956
target		<http://example.com/preference/{ID}> a cmtstructured:Preference . 
source		SELECT "ID" FROM "Preference"

mappingId	mapping-385761635
target		<http://example.com/conference/{Conference}> cmtstructured:reviewerBiddingStartedBy <http://example.com/person/{Administrator}> . 
source		SELECT "Conference" , "Administrator" FROM "reviewerBiddingStartedBy"

mappingId	mapping-810391234
target		<http://example.com/document/{ID}> a cmtstructured:Document . 
source		SELECT "ID" FROM "Document"

mappingId	mapping-2048754096
target		<http://example.com/conference/{ID}> a cmtstructured:Conference ; cmtstructured:siteurl {siteURL}^^xsd:anyURI ; cmtstructured:siteURL {siteURL}^^xsd:anyURI ; cmtstructured:reviewsPerPaper {reviewsPerPaper}^^xsd:int ; cmtstructured:name {name}^^xsd:string ; cmtstructured:date {date}^^xsd:date ; cmtstructured:logourl {logoURL}^^xsd:anyURI ; cmtstructured:logoURL {logoURL}^^xsd:anyURI . 
source		SELECT "ID" , "siteURL" , "acceptsHardcopySubmissions" , "logoURL" , "date" , "name" , "reviewsPerPaper" FROM "Conference"

mappingId	mapping-1241262717
target		<http://example.com/document/{ID}> a cmtstructured:PaperFullVersion . 
source		SELECT "ID" FROM "Paper" WHERE "TYPE" = 1

mappingId	mapping--2124453776
target		<http://example.com/document/{ID}> a cmtstructured:PaperAbstract . 
source		SELECT "ID" FROM "Paper" WHERE "TYPE" = 2

mappingId	mapping--1143772879
target		<http://example.com/conference/{Conference}> cmtstructured:hardcopyMailingManifestsPrintedBy <http://example.com/person/{Administrator}> . 
source		SELECT "Conference" , "Administrator" FROM "hardcopyMailingManifestsP"

mappingId	mapping-968945947
target		<http://example.com/person/{ID}> a cmtstructured:Co-author . 
source		SELECT "ID" FROM "Person" WHERE "is_Co-author" = true

mappingId	mapping--1702198655
target		<http://example.com/conference/{Conference}> cmtstructured:paperAssignmentToolsRunBy <http://example.com/person/{Administrator}> . 
source		SELECT "Conference" , "Administrator" FROM "paperAssignmentToolsRunBy"

mappingId	mapping-1437004305
target		<http://example.com/person/{ID}> a cmtstructured:ProgramCommitteeMember ; cmtstructured:maxPapers {maxPapers}^^xsd:int ; cmtstructured:addedBy <http://example.com/person/{addedBy}> . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeMember"

mappingId	mapping--2060407151
target		<http://example.com/document/{ID}> a cmtstructured:Review ; rdfs:comment {comment}^^xsd:string ; cmtstructured:title {comment}^^xsd:string ; cmtstructured:writtenBy <http://example.com/person/{writtenBy}> . 
source		SELECT "ID" , "writtenBy" , "comment" , "TYPE" FROM "Review"

mappingId	mapping-615328197
target		<http://example.com/document/{Paper}> cmtstructured:assignedTo <http://example.com/person/{Reviewer}> . 
source		SELECT "Paper" , "Reviewer" FROM "assignedTo"
]]

