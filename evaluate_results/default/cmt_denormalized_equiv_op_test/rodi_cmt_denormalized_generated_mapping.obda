[PrefixDeclaration]
rr:		http://www.w3.org/ns/r2rml#
rdf:		http://www.w3.org/1999/02/22-rdf-syntax-ns#
rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#
cmtdenormalized:	http://cmt#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping-169361077
target		<http://example.com/rejection/{ID}> a cmtdenormalized:Rejection . 
source		SELECT "ID" FROM "Rejection"

mappingId	mapping--1267795973
target		<http://example.com/user/{Administrator}> cmtdenormalized:enterReviewCriteria <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "enterReviewCriteria"

mappingId	mapping--469501670
target		<http://example.com/person/{ID}> a cmtdenormalized:AuthorNotReviewer . 
source		SELECT "ID" FROM "Author" WHERE "TYPE" = 0

mappingId	mapping-40403569
target		<http://example.com/document/{ID}> cmtdenormalized:rejectedBy <http://example.com/user/{rejectedBy}> ; cmtdenormalized:paperid {paperID}^^xsd:unsignedLong ; cmtdenormalized:readByMeta-Reviewer <http://example.com/user/{readByMeta-Reviewer}> ; cmtdenormalized:hasAuthor <http://example.com/person/{hasAuthor}> ; cmtdenormalized:title {title}^^xsd:string ; cmtdenormalized:paperID {paperID}^^xsd:unsignedLong ; cmtdenormalized:hasDecision <http://example.com/rejection/{hasDecision}> ; cmtdenormalized:acceptedBy <http://example.com/user/{acceptedBy}> . 
source		SELECT "ID" , "paperID" , "rejectedBy" , "readByMeta-Reviewer" , "hasAuthor" , "title" , "hasDecision" , "acceptedBy" , "TYPE" , "Reviewer" FROM "Paper"

