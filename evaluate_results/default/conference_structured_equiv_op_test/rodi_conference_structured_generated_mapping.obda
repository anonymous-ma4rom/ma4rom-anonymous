[MappingDeclaration] @collection [[
mappingId	mapping--1524824716
target		<http://example.com/important_dates/{ID}> a conferencestructured:Important_dates ; conferencestructured:is_an_ending_date {is_an_ending_date}^^xsd:date ; conferencestructured:is_a_date_of_camera_ready_paper_submission {is_a_date_of_camera_ready}^^xsd:date ; conferencestructured:is_a_full_paper_submission_date {is_a_full_paper_submissio}^^xsd:date ; conferencestructured:is_a_date_of_acceptance_announcement {is_a_date_of_acceptance_a}^^xsd:date ; conferencestructured:is_an_abstract_submission_date {is_an_abstract_submission}^^xsd:date ; conferencestructured:is_a_starting_date {is_a_starting_date}^^xsd:date . 
source		SELECT "ID" , "is_a_date_of_acceptance_a" , "is_a_full_paper_submissio" , "is_a_date_of_camera_ready" , "is_an_ending_date" , "is_a_starting_date" , "is_an_abstract_submission" FROM "Important_dates"

