[MappingDeclaration] @collection [[
mappingId	mapping--12828394
target		<http://sws.ifi.uio.no/data/npd-v2/seamultiline/{seasurveyname}> a <http://www.opengis.net/ont/gml#MultiSolid> ; <http://sws.ifi.uio.no/vocab/npd-v2#lengthPlannedCdpKm> {seaplancdpkm}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#sourcePressure> {seasourcepressure}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#lengthPlannedBoatKm> {seacdptotalkm}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#sensorNumbers> {seasensornumbers}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#dateFieldOwnerTo> {seadatefinalized}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#sourceSize> {seasourcesize}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#dateUpdatedMax> {seaplantodate}^^xsd:dateTime ; <http://sws.ifi.uio.no/vocab/npd-v2#companyShare> {seaplanboatkm}^^xsd:decimal ; <http://sws.ifi.uio.no/vocab/npd-v2#status> {seastatus}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#sensorLength> {seasensorlength}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#lengthBoatTotalKm> {seaboattotalkm}^^xsd:integer ; <http://sws.ifi.uio.no/vocab/npd-v2#sourceNumber> {seasourcenumber}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#dateTransferValidFrom> {seaplanfromdate}^^xsd:dateTime . 
source		SELECT "seasurveyname" , "seafactmapurl" , "seafactpageurl" , "seastatus" , "seamarketavailable" , "seasurveytypemain" , "seasurveytypepart" , "seacompanyreported" , "seasourcetype" , "seasourcenumber" , "seasourcesize" , "seasourcepressure" , "seasensortype" , "seasensornumbers" , "seasensorlength" , "seaplanfromdate" , "seadatestarting" , "seaplantodate" , "seadatefinalized" , "seaplancdpkm" , "seacdptotalkm" , "seaplanboatkm" , "seaboattotalkm" FROM "seamultiline"

mappingId	mapping-1723488859
target		<http://sws.ifi.uio.no/data/npd-v2/field_description/{fldnpdidfield}__{flddescriptionheading}> a <http://sws.ifi.uio.no/vocab/npd-v2#ProductionLicence> ; <http://sws.ifi.uio.no/vocab/npd-v2#licensingActivityName> {flddescriptiontext}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2-ptl#name> {fldname}^^xsd:string ; <http://sws.ifi.uio.no/vocab/npd-v2#dateLicenceGranted> {flddescriptiondateupdated}^^xsd:dateTime . 
