# === licence_petreg_licence (SH) ===
<#licence_petreg_licenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ptlname\" , \"ptldateawarded\" , \"ptldatevalidfrom\" , \"ptldatevalidto\" , \"prlnpdidlicence\" , \"ptldateupdated\" , \"ptldateupdatedmax\" , \"datesyncnpd\" FROM \"licence_petreg_licence\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/licence/{prlnpdidlicence}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#ProductionLicence> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "ptlname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2-ptl#dateAwarded> ;
        rr:objectMap [ rr:column "ptldateawarded" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateLicenceGranted> ;
        rr:objectMap [ rr:column "ptldatevalidfrom" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateLicenceGranted> ;
        rr:objectMap [ rr:column "ptldatevalidto" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateUpdated> ;
        rr:objectMap [ rr:column "ptldateupdated" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateUpdatedMax> ;
        rr:objectMap [ rr:column "ptldateupdatedmax" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#datesyncnpd> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] .

