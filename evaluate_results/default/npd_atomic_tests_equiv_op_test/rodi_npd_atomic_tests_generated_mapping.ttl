        rr:objectMap [ rr:column "fldrecoverablengl" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverablengl> ;
        rr:objectMap [ rr:column "fldrecoverablengl" ; rr:datatype xsd:decimal ]
