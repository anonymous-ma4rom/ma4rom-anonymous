    rr:logicalTable [ rr:sqlQuery "SELECT \"wlbname\" , \"wlbcasingtype\" , \"wlbcasingdiameter\" , \"wlbcasingdepth\" , \"wlbholediameter\" , \"wlbholedepth\" , \"wlblotmuddencity\" , \"wlbnpdidwellbore\" , \"wlbcasingdateupdated\" , \"datesyncnpd\" , \"wellbore_casing_and_lot_id\" FROM \"wellbore_casing_and_lot\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_casing_and_lot/{wellbore_casing_and_lot_id}__{wlbnpdidwellbore}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#WellboreCasingAndLeakoffTest> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#casingDiameter> ;
        rr:objectMap [ rr:column "wlbcasingdiameter" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#casingDepth> ;
        rr:objectMap [ rr:column "wlbcasingdepth" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#wellboreHoleDiameter> ;
        rr:objectMap [ rr:column "wlbholediameter" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#wellboreHoleDepth> ;
        rr:objectMap [ rr:column "wlbholedepth" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#LOTMudDensity> ;
        rr:objectMap [ rr:column "wlblotmuddencity" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#lotmuddensity> ;
        rr:objectMap [ rr:column "wlblotmuddencity" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#datesyncnpd> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#wellboreHoleDepth> ;
        rr:objectMap [ rr:column "wlbnpdidwellbore" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#wellboreHoleDiameter> ;
        rr:objectMap [ rr:column "wellbore_casing_and_lot_id" ; rr:datatype xsd:int ]
    ] .

