    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableCondensate> ;
        rr:objectMap [ rr:column "fldrecoverablecondensate" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableOil> ;
        rr:objectMap [ rr:column "fldrecoverableoe" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#remainingOil> ;
        rr:objectMap [ rr:column "fldremainingoil" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#remainingGas> ;
        rr:objectMap [ rr:column "fldremaininggas" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#remainingNGL> ;
        rr:objectMap [ rr:column "fldremainingngl" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#remainingngl> ;
        rr:objectMap [ rr:column "fldremainingngl" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#remainingCondensate> ;
        rr:objectMap [ rr:column "fldremainingcondensate" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#remainingOil> ;
