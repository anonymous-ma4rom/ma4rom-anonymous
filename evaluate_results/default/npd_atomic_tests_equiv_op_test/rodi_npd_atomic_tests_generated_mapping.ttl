    rr:logicalTable [ rr:sqlQuery "SELECT \"fldname\" , \"fldstatusfromdate\" , \"fldstatustodate\" , \"fldstatus\" , \"fldnpdidfield\" , \"fldstatusdateupdated\" , \"datesyncnpd\" FROM \"field_activity_status_hst\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field_activity_status_hst/{fldnpdidfield}__{fldstatus}__{fldstatusfromdate}__{fldstatustodate}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#SubseaStructureFacility> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "fldname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateStatusValidFrom> ;
        rr:objectMap [ rr:column "fldstatusdateupdated" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#datesyncnpd> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateStatusValidFrom> ;
        rr:objectMap [ rr:column "fldstatusfromdate" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateStatusValidTo> ;
        rr:objectMap [ rr:column "fldstatustodate" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#status> ;
        rr:objectMap [ rr:column "fldstatus" ; rr:datatype xsd:string ]
