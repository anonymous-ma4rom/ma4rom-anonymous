# === wellbore_coordinates (SH) ===
<#wellbore_coordinatesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"wlbwellborename\" , \"wlbdrillingoperator\" , \"wlbproductionlicence\" , \"wlbwelltype\" , \"wlbpurposeplanned\" , \"wlbcontent\" , \"wlbentrydate\" , \"wlbcompletiondate\" , \"wlbfield\" , \"wlbmainarea\" , \"wlbgeodeticdatum\" , \"wlbnsdeg\" , \"wlbnsmin\" , \"wlbnssec\" , \"wlbnscode\" , \"wlbewdeg\" , \"wlbewmin\" , \"wlbewsec\" , \"wlbewcode\" , \"wlbnsdecdeg\" , \"wlbewdesdeg\" , \"wlbnsutm\" , \"wlbewutm\" , \"wlbutmzone\" , \"wlbnpdidwellbore\" , \"datesyncnpd\" FROM \"wellbore_coordinates\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_npdid_overview/{wlbnpdidwellbore}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#WellboreCoordinate> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#wellboreParent> ;
        rr:objectMap [ rr:column "wlbwellborename" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#wellborePlannedPurpose> ;
