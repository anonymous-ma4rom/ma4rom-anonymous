[MappingDeclaration] @collection [[
mappingId	mapping--886510600
target		<http://example.com/important_dates/{ID}> a conferencestructured:Important_dates ; conferencestructured:is_a_starting_date {is_a_starting_date}^^xsd:date ; conferencestructured:is_an_ending_date {is_an_ending_date}^^xsd:date ; conferencestructured:is_a_date_of_camera_ready_paper_submission {is_a_date_of_camera_ready}^^xsd:date ; conferencestructured:is_a_full_paper_submission_date {is_a_full_paper_submissio}^^xsd:date ; conferencestructured:is_a_date_of_acceptance_announcement {is_a_date_of_acceptance_a}^^xsd:date ; conferencestructured:is_an_abstract_submission_date {is_an_abstract_submission}^^xsd:date . 
source		SELECT "ID" , "is_a_date_of_acceptance_a" , "is_a_full_paper_submissio" , "is_a_date_of_camera_ready" , "is_an_ending_date" , "is_a_starting_date" , "is_an_abstract_submission" FROM "Important_dates"

mappingId	mapping--585887095
target		<http://example.com/conference_document/{ID}> a conferencestructured:Paper ; conferencestructured:is_submitted_at <http://example.com/conference_volume/{is_submitted_at}> ; conferencestructured:has_a_paper_title {has_a_paper_title}^^xsd:string ; conferencestructured:has_an_abstract <http://example.com/conference_document/{has_an_abstract}> . 
source		SELECT "ID" , "has_an_abstract" , "has_a_paper_title" , "is_submitted_at" , "TYPE" FROM "Paper"

mappingId	mapping-129574970
