[MappingDeclaration] @collection [[
mappingId	mapping-1683066921
target		<http://example.com/sea/{name}> a mondialrel:Sea ; mondialrel:depth {depth}^^xsd:decimal ; mondialrel:name {name}^^xsd:string . 
source		SELECT "name" , "depth" FROM "sea"

mappingId	mapping-488876334
target		<http://example.com/island/{name}> a mondialrel:Island ; mondialrel:area {area}^^xsd:decimal ; mondialrel:elevation {elevation}^^xsd:decimal ; mondialrel:name {name}^^xsd:string . 
source		SELECT "name" , "islands" , "area" , "elevation" , "type" , "coordinates" FROM "island"

mappingId	mapping-1648421896
target		<http://example.com/country/{country}> a mondialrel:Country ; mondialrel:gdpAgri {agriculture}^^xsd:decimal ; mondialrel:inflation {inflation}^^xsd:decimal ; mondialrel:gdpServ {service}^^xsd:decimal ; mondialrel:unemployment {unemployment}^^xsd:decimal ; mondialrel:gdpTotal {gdp}^^xsd:decimal ; mondialrel:gdpInd {industry}^^xsd:decimal . 
source		SELECT "country" , "gdp" , "agriculture" , "service" , "industry" , "inflation" , "unemployment" FROM "economy"

mappingId	mapping-1847502625
