    rr:predicateObjectMap [
        rr:predicate mondialrel:locatedInWater ;
        rr:objectMap [ rr:template "http://example.com/lake/{lake}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:locatedInWater ;
        rr:objectMap [ rr:template "http://example.com/river/{river}" ]
    ] .

