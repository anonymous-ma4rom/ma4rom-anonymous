# === islandin (SE) ===
<#islandinMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"island\" , \"sea\" , \"lake\" , \"river\" FROM \"islandin\"" ] ;
