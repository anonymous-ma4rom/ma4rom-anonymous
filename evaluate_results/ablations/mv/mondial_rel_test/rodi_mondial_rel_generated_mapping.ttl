    ] .

# === mountainonisland (SR) ===
<#mountainonislandMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"mountain\" , \"island\" FROM \"mountainonisland\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/mountain/{mountain}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:locatedOnIsland ;
        rr:objectMap [ rr:template "http://example.com/island/{island}" ]
    ] .

# === riverthrough (SR) ===
<#riverthroughMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"lake\" , \"river\" FROM \"riverthrough\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/lake/{lake}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasBorder ;
        rr:objectMap [ rr:template "http://example.com/river/{river}" ]
    ] .

# === airport (SE) ===
<#airportMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"iatacode\" , \"name\" , \"country\" , \"city\" , \"province\" , \"island\" , \"latitude\" , \"longitude\" , \"elevation\" , \"gmtoffset\" FROM \"airport\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/airport/{iatacode}" ; rr:class mondialrel:Location ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasCity ;
        rr:objectMap [ rr:template "http://example.com/city/{city}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:isProvinceOf ;
        rr:objectMap [ rr:template "http://example.com/city/{province}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:locatedOnIsland ;
        rr:objectMap [ rr:template "http://example.com/island/{island}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:latitude ;
        rr:objectMap [ rr:column "latitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:longitude ;
        rr:objectMap [ rr:column "longitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:elevation ;
        rr:objectMap [ rr:column "elevation" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:longitude ;
        rr:objectMap [ rr:column "gmtoffset" ; rr:datatype xsd:decimal ]
    ] .

# === borders (SE) ===
<#bordersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country1\" , \"country2\" , \"length\" FROM \"borders\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/borders/{country1}__{country2}" ; rr:class mondialrel:Border ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:length ;
        rr:objectMap [ rr:column "length" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:bordering ;
        rr:objectMap [ rr:template "http://example.com/country/{country1}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:bordering ;
        rr:objectMap [ rr:template "http://example.com/country/{country2}" ]
    ] .

# === city (SE) ===
<#cityMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"country\" , \"province\" , \"population\" , \"latitude\" , \"longitude\" , \"elevation\" FROM \"city\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/city/{name}__{country}__{province}" ; rr:class mondialrel:City ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:population ;
        rr:objectMap [ rr:column "population" ; rr:datatype xsd:nonNegativeInteger ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:latitude ;
        rr:objectMap [ rr:column "latitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:longitude ;
        rr:objectMap [ rr:column "longitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:elevation ;
        rr:objectMap [ rr:column "elevation" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:cityIn ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/province/{province}" ]
    ] .

# === cityothername (SE) ===
<#cityothernameMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"city\" , \"country\" , \"province\" , \"othername\" FROM \"cityothername\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/cityothername/{country}__{province}__{city}__{othername}" ; rr:class mondialrel:City ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:cityIn ;
        rr:objectMap [ rr:template "http://example.com/country/{country}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:othername ;
        rr:objectMap [ rr:column "othername" ; rr:datatype xsd:string ]
    ] .

# === continent (SE) ===
<#continentMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"area\" FROM \"continent\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/continent/{name}" ; rr:class mondialrel:Continent ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:area ;
        rr:objectMap [ rr:column "area" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] .

# === country (SE) ===
<#countryMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"code\" , \"capital\" , \"province\" , \"area\" , \"population\" FROM \"country\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/country/{code}" ; rr:class mondialrel:Country ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:capital ;
        rr:objectMap [ rr:template "http://example.com/city/{capital}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/city/{province}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:area ;
        rr:objectMap [ rr:column "area" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:population ;
        rr:objectMap [ rr:column "population" ; rr:datatype xsd:nonNegativeInteger ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:carCode ;
        rr:objectMap [ rr:column "code" ; rr:datatype xsd:string ]
    ] .

# === desert (SE) ===
<#desertMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"area\" , \"coordinates\" FROM \"desert\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/desert/{name}" ; rr:class mondialrel:Desert ] ;
