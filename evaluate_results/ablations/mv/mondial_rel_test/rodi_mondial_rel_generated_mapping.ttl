@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mondialrel: <http://www.semwebtech.org/mondial/10/meta#> .
@base <http://example.com/> .

# === countryothername (SH) ===
<#countryothernameMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"othername\" FROM \"countryothername\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/countryothername/{country}__{othername}" ; rr:class mondialrel:Country ] .

# === economy (SH) ===
<#economyMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"gdp\" , \"agriculture\" , \"service\" , \"industry\" , \"inflation\" , \"unemployment\" FROM \"economy\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/country/{country}" ; rr:class mondialrel:Country ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:gdpTotal ;
        rr:objectMap [ rr:column "gdp" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:gdpAgri ;
        rr:objectMap [ rr:column "agriculture" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:gdpServ ;
        rr:objectMap [ rr:column "service" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:gdpInd ;
        rr:objectMap [ rr:column "industry" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:inflation ;
        rr:objectMap [ rr:column "inflation" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:unemployment ;
        rr:objectMap [ rr:column "unemployment" ; rr:datatype xsd:decimal ]
    ] .

# === politics (SH) ===
<#politicsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"independence\" , \"wasdependent\" , \"dependent\" , \"government\" FROM \"politics\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/country/{country}" ; rr:class mondialrel:PoliticalBody ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:independenceDate ;
        rr:objectMap [ rr:column "independence" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:dependentOf ;
        rr:objectMap [ rr:template "http://example.com/country/{dependent}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:government ;
        rr:objectMap [ rr:column "government" ; rr:datatype xsd:string ]
    ] .

# === population (SH) ===
<#populationMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"population_growth\" , \"infant_mortality\" FROM \"population\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/country/{country}" ; rr:class mondialrel:PopulationCount ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:populationGrowth ;
        rr:objectMap [ rr:column "population_growth" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:infantMortality ;
        rr:objectMap [ rr:column "infant_mortality" ; rr:datatype xsd:decimal ]
    ] .

# === geo_desert (SR) ===
<#geo_desertMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"desert\" , \"country\" FROM \"geo_desert\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/desert/{desert}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === geo_estuary (SR) ===
<#geo_estuaryMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"river\" , \"country\" FROM \"geo_estuary\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/river/{river}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasEstuary ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === geo_island (SR) ===
<#geo_islandMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"island\" , \"country\" FROM \"geo_island\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/island/{island}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

