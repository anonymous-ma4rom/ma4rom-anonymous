<#geo_lakeMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"lake\" , \"country\" FROM \"geo_lake\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/lake/{lake}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === geo_mountain (SR) ===
<#geo_mountainMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"mountain\" , \"country\" FROM \"geo_mountain\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/mountain/{mountain}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === geo_river (SR) ===
<#geo_riverMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"river\" , \"country\" FROM \"geo_river\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/river/{river}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === geo_sea (SR) ===
<#geo_seaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"sea\" , \"country\" FROM \"geo_sea\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/sea/{sea}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === geo_source (SR) ===
<#geo_sourceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"river\" , \"country\" FROM \"geo_source\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/river/{river}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasSource ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === locatedon (SR) ===
<#locatedonMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"city\" , \"country\" FROM \"locatedon\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/city/{city}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:locatedAt ;
        rr:objectMap [ rr:template "http://example.com/city/{country}" ]
    ] .

# === mergeswith (SR) ===
<#mergeswithMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"sea1\" , \"sea2\" FROM \"mergeswith\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/sea/{sea1}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:mergesWith ;
