    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] .

# === encompasses (SE) ===
<#encompassesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"continent\" , \"percentage\" FROM \"encompasses\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/encompasses/{country}__{continent}" ; rr:class mondialrel:Encompassed ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:percent ;
        rr:objectMap [ rr:column "percentage" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:cityIn ;
        rr:objectMap [ rr:template "http://example.com/country/{country}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:encompassedBy ;
        rr:objectMap [ rr:template "http://example.com/continent/{continent}" ]
    ] .

