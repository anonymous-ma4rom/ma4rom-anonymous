target		<http://example.com/person/{Author}> sigkddstructured:notification_until <http://example.com/deadline_abstract_submiss/{Deadline_Author_notificat}> . 
source		SELECT "Author" , "Deadline_Author_notificat" FROM "notification_until"

mappingId	mapping--1937787640
target		<http://example.com/conference/{ID}> a sigkddstructured:Conference ; sigkddstructured:Start_of_conference {Start_of_conference}^^xsd:dateTime ; sigkddstructured:holded_by <http://example.com/acm_sigkdd/{holded_by}> ; sigkddstructured:End_of_conference {End_of_conference}^^xsd:dateTime ; sigkddstructured:Name_of_conference {Name_of_conference}^^xsd:string ; sigkddstructured:City_of_conference {City_of_conference}^^xsd:string . 
