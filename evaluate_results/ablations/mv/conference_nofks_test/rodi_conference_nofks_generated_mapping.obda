mappingId	mapping--52711031
target		<http://example.com/conference_volume/{ID}> a conferencenofks:Conference_volume ; conferencenofks:has_a_name {has_a_name}^^xsd:string ; conferencenofks:has_a_location {has_a_program_committee}^^xsd:string , {has_a_steering_committee}^^xsd:string , {has_an_organizing_committ}^^xsd:string , {has_a_location}^^xsd:string . 
source		SELECT "ID" , "has_a_program_committee" , "has_an_organizing_committ" , "has_a_location" , "has_a_steering_committee" , "has_important_dates" , "has_a_name" FROM "Conference_volume"

