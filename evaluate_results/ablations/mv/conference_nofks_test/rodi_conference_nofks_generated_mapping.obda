[PrefixDeclaration]
rr:		http://www.w3.org/ns/r2rml#
rdf:		http://www.w3.org/1999/02/22-rdf-syntax-ns#
rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#
conferencenofks:	http://conference#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping--776575126
target		<http://example.com/important_dates/{ID}> a conferencenofks:Important_dates ; conferencenofks:is_a_starting_date {is_a_starting_date}^^xsd:date ; conferencenofks:is_an_abstract_submission_date {is_an_abstract_submission}^^xsd:date ; conferencenofks:is_a_date_of_camera_ready_paper_submission {is_a_date_of_camera_ready}^^xsd:date ; conferencenofks:is_an_ending_date {is_an_ending_date}^^xsd:date ; conferencenofks:is_a_date_of_acceptance_announcement {is_a_date_of_acceptance_a}^^xsd:date ; conferencenofks:is_a_full_paper_submission_date {is_a_full_paper_submissio}^^xsd:date . 
source		SELECT "ID" , "is_a_date_of_acceptance_a" , "is_a_full_paper_submissio" , "is_a_date_of_camera_ready" , "is_an_ending_date" , "is_a_starting_date" , "is_an_abstract_submission" FROM "Important_dates"

mappingId	mapping-1393379386
target		<http://example.com/paper/{ID}> a conferencenofks:Paper ; conferencenofks:is_submitted_at <http://example.com/conference_volume/{is_submitted_at}> ; conferencenofks:has_an_abstract <http://example.com/abstract/{has_an_abstract}> ; conferencenofks:has_a_paper_title {has_a_paper_title}^^xsd:string . 
source		SELECT "ID" , "has_an_abstract" , "has_a_paper_title" , "is_submitted_at" , "TYPE" FROM "Paper"

mappingId	mapping-800279437
target		<http://example.com/conference_proceedings/{ID}> a conferencenofks:Conference_proceedings ; conferencenofks:has_an_ISBN {has_an_ISBN}^^xsd:string ; conferencenofks:has_a_name {has_a_name}^^xsd:string ; conferencenofks:has_a_volume {has_a_publisher}^^xsd:int , {has_a_volume}^^xsd:int . 
source		SELECT "ID" , "has_a_publisher" , "has_a_volume" , "has_a_name" , "has_an_ISBN" FROM "Conference_proceedings"

mappingId	mapping--1710235031
target		<http://example.com/conference_document/{ID}> a conferencenofks:Conference_document ; conferencenofks:has_a_date_of_issue {has_a_date_of_issue}^^xsd:date ; conferencenofks:has_a_URL {has_a_URL}^^xsd:string . 
source		SELECT "ID" , "has_a_date_of_issue" , "has_a_URL" , "TYPE" FROM "Conference_document"

mappingId	mapping--211278729
target		<http://example.com/organizer/{ID}> a conferencenofks:Organizer . 
source		SELECT "ID" FROM "Organizer"

mappingId	mapping--1970293194
target		<http://example.com/person/{ID}> a conferencenofks:Person ; conferencenofks:has_the_last_name {has_the_last_name}^^xsd:string ; conferencenofks:has_gender {has_gender}^^xsd:string ; conferencenofks:has_the_first_name {has_the_first_name}^^xsd:string . 
source		SELECT "ID" , "has_the_first_name" , "has_the_last_name" , "has_gender" , "is_Conference_contributor" , "is_Contribution_co-author" , "is_Committee_member" , "is_Chair" , "is_Contribution_1th-author" , "is_Reviewer" , "TYPE" FROM "Person"

mappingId	mapping-1899579191
target		<http://example.com/person/{ID}> a conferencenofks:Contribution_1th-author . 
source		SELECT "ID" FROM "Person" WHERE "is_Contribution_1th-author" = true

mappingId	mapping--980134542
target		<http://example.com/person/{ID}> a conferencenofks:Committee_member . 
