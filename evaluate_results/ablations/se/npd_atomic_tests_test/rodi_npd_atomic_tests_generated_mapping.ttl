@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix npdatomictests: <http://def.seegrid.csiro.au/isotc211/iso19103/2005/basic#> .
@base <http://sws.ifi.uio.no/data/npd-v2/> .

# === bsns_arr_area_operator (SH) ===
<#bsns_arr_area_operatorMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"baaname\" , \"cmplongname\" , \"baanpdidbsnsarrarea\" , \"cmpnpdidcompany\" , \"baaoperatordateupdated\" , \"datesyncnpd\" FROM \"bsns_arr_area_operator\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/bsns_arr_area/{baanpdidbsnsarrarea}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#CompressedNaturalGas> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "baaname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#drillingOperatorCompany> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/company/{cmpnpdidcompany}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateOperatorValidTo> ;
        rr:objectMap [ rr:column "baaoperatordateupdated" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] .

# === fclpoint (SH) ===
<#fclpointMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"fclnpdidfacility\" , \"fclsurface\" , \"fclcurrentoperatorname\" , \"fclname\" , \"fclkind\" , \"fclbelongstoname\" , \"fclbelongstokind\" , \"fclbelongstos\" , \"fclstartupdate\" , \"fclwaterdepth\" , \"fclfunctions\" , \"fcldesignlifetime\" , \"fclfactpageurl\" , \"fclfactmapurl\" FROM \"fclpoint\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/facility_fixed/{fclnpdidfacility}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#Point> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "fclname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#coresTotalLength> ;
        rr:objectMap [ rr:column "fclbelongstos" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateStatusFrom> ;
        rr:objectMap [ rr:column "fclstartupdate" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#waterDepth> ;
        rr:objectMap [ rr:column "fclwaterdepth" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#facilityFunction> ;
        rr:objectMap [ rr:column "fclfunctions" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#designLifetime> ;
        rr:objectMap [ rr:column "fcldesignlifetime" ; rr:datatype xsd:integer ]
    ] .

# === field_reserves (SH) ===
<#field_reservesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"fldname\" , \"fldrecoverableoil\" , \"fldrecoverablegas\" , \"fldrecoverablengl\" , \"fldrecoverablecondensate\" , \"fldrecoverableoe\" , \"fldremainingoil\" , \"fldremaininggas\" , \"fldremainingngl\" , \"fldremainingcondensate\" , \"fldremainingoe\" , \"flddateoffresestdisplay\" , \"fldnpdidfield\" , \"datesyncnpd\" FROM \"field_reserves\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field/{fldnpdidfield}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#FieldReserve> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "fldname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableOil> ;
        rr:objectMap [ rr:column "fldrecoverableoil" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableGas> ;
        rr:objectMap [ rr:column "fldrecoverablegas" ; rr:datatype xsd:decimal ]
