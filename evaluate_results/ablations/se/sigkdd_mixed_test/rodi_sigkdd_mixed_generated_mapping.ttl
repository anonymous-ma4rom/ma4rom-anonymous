@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sigkddmixed: <http://sigkdd#> .
@base <http://example.com/> .

# === reviews (SH) ===
<#reviewsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"ref\" , \"review\" , \"internal_id\" , \"text\" FROM \"reviews\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{id}" ; rr:class sigkddmixed:Review ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:isReviewOf ;
        rr:objectMap [ rr:template "http://example.com/documents/{ref}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:isReviewOf ;
        rr:objectMap [ rr:template "http://example.com/documents/{review}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:hasID ;
        rr:objectMap [ rr:column "internal_id" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:hasText ;
        rr:objectMap [ rr:column "text" ; rr:datatype xsd:string ]
    ] .

# === acm_sigkdd_person (SR) ===
<#acm_sigkdd_personMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"aid\" , \"pid\" FROM \"acm_sigkdd_person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/acm_sigkdds/{aid}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:search ;
        rr:objectMap [ rr:template "http://example.com/persons/{pid}" ]
    ] .

# === document_deadline_abstract_submiss (SR) ===
<#document_deadline_abstract_submissMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"document\" , \"deadline\" FROM \"document_deadline_abstract_submiss\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{document}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:submit_until ;
        rr:objectMap [ rr:template "http://example.com/deadline_abstract_submiss/{deadline}" ]
    ] .

# === document_person (SR) ===
<#document_personMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"did\" FROM \"document_person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:presentation ;
        rr:objectMap [ rr:template "http://example.com/documents/{did}" ]
    ] .

# === main_office_person (SR) ===
<#main_office_personMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"mid\" FROM \"main_office_person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:can_stay_in ;
        rr:objectMap [ rr:template "http://example.com/main_offices/{mid}" ]
    ] .

# === person_best_research_paper_award (SR) ===
<#person_best_research_paper_awardMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"bid\" FROM \"person_best_research_paper_award\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:can_stay_in ;
        rr:objectMap [ rr:template "http://example.com/best_research_paper_awards/{bid}" ]
    ] .

# === person_deadline_abstract_submiss (SR) ===
<#person_deadline_abstract_submissMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"did\" FROM \"person_deadline_abstract_submiss\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:can_stay_in ;
        rr:objectMap [ rr:template "http://example.com/deadline_abstract_submiss/{did}" ]
    ] .

# === presentation (SR) ===
<#presentationMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"did\" , \"pid\" FROM \"presentation\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{did}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:presentationed_by ;
        rr:objectMap [ rr:template "http://example.com/persons/{pid}" ]
    ] .

# === registration_fee_person (SR) ===
<#registration_fee_personMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"rid\" FROM \"registration_fee_person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddmixed:pay ;
        rr:objectMap [ rr:template "http://example.com/registration_fees/{rid}" ]
    ] .

# === e_mails (MV) ===
<#e_mailsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"person\" , \"value\" FROM \"e_mails\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{person}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sigkdd#E-mail> ;
        rr:objectMap [ rr:column "value" ; rr:datatype xsd:string ]
    ] .
