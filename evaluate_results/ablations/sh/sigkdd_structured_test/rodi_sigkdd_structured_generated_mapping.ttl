    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:Price ;
        rr:objectMap [ rr:column "Price" ; rr:datatype xsd:int ]
    ] .

# === Document (Type Assertions) ===
<#Document_TYPE_1_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Document\" WHERE \"TYPE\" = 1" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddstructured:Paper ]
    ] .

<#Document_TYPE_2_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Document\" WHERE \"TYPE\" = 2" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddstructured:Abstract ]
    ] .

<#Document_TYPE_3_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Document\" WHERE \"TYPE\" = 3" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddstructured:Review ]
    ] .

