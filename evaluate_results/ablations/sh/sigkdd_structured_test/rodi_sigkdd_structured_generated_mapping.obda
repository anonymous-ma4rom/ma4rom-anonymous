mappingId	mapping-1764719404
target		<http://example.com/program_committee/{ID}> a sigkddstructured:Program_Committee ; rdfs:label {label}^^xsd:string ; sigkddstructured:E-mail {label}^^xsd:string ; sigkddstructured:isCommitteeOf <http://example.com/conference/{hasCommittee_Inv}> , <http://example.com/conference/{isCommitteeOf}> . 
source		SELECT "ID" , "label" , "hasCommittee_Inv" , "isCommitteeOf" FROM "Program_Committee"

mappingId	mapping--1532594017
target		<http://example.com/person/{ID}> a sigkddstructured:Organizator . 
source		SELECT "ID" FROM "Person" WHERE "is_Organizator" = true
