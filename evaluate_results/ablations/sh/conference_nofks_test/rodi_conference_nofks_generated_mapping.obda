mappingId	mapping-1764380460
target		<http://example.com/conference_volume/{ID}> a conferencenofks:Conference_volume ; conferencenofks:has_a_location {has_a_program_committee}^^xsd:string , {has_a_location}^^xsd:string , {has_an_organizing_committ}^^xsd:string , {has_a_steering_committee}^^xsd:string ; conferencenofks:has_a_name {has_a_name}^^xsd:string . 
