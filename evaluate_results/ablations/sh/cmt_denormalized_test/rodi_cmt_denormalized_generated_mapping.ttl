# === hasSubjectArea (MV) ===
<#hasSubjectAreaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"SubjectArea\" , \"Paper\" FROM \"hasSubjectArea\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/subjectarea/{SubjectArea}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasSubjectArea ;
