<#hasConflictOfInterestMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Document\" , \"Person\" FROM \"hasConflictOfInterest\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{Document}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasConflictOfInterest ;
        rr:objectMap [ rr:template "http://example.com/person/{Person}" ]
    ] .

