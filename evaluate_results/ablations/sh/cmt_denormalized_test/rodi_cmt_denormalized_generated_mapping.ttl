    ] .

# === paperAssignmentToolsRunBy (SR) ===
<#paperAssignmentToolsRunByMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference\" , \"Administrator\" FROM \"paperAssignmentToolsRunBy\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{Conference}" ] ;
