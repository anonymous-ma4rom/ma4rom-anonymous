# === submitPaper (MV) ===
<#submitPaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Author\" , \"Paper\" FROM \"submitPaper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/author/{Author}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:submitPaper ;
        rr:objectMap [ rr:template "http://example.com/paper/{Paper}" ]
    ] .

# === Bid (SE) ===
<#BidMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"adjustedBy\" , \"hasBid_Inv\" FROM \"Bid\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/bid/{ID}" ; rr:class cmtdenormalized:Bid ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasBid ;
        rr:objectMap [ rr:template "http://example.com/paper/{hasBid_Inv}" ]
    ] .

# === Conference (SE) ===
<#ConferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"siteURL\" , \"acceptsHardcopySubmissions\" , \"logoURL\" , \"date\" , \"name\" , \"reviewsPerPaper\" FROM \"Conference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{ID}" ; rr:class cmtdenormalized:Conference ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:siteURL ;
        rr:objectMap [ rr:column "siteURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:logoURL ;
        rr:objectMap [ rr:column "logoURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:date ;
        rr:objectMap [ rr:column "date" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:reviewsPerPaper ;
        rr:objectMap [ rr:column "reviewsPerPaper" ; rr:datatype xsd:int ]
    ] .

# === Document (SE) ===
<#DocumentMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"writtenBy\" , \"TYPE\" FROM \"Document\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ; rr:class cmtdenormalized:Document ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:writtenBy ;
        rr:objectMap [ rr:template "http://example.com/person/{writtenBy}" ]
    ] .

# === Paper (SE) ===
<#PaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"paperID\" , \"rejectedBy\" , \"readByMeta-Reviewer\" , \"hasAuthor\" , \"title\" , \"hasDecision\" , \"acceptedBy\" , \"TYPE\" , \"Reviewer\" FROM \"Paper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/paper/{ID}__{Reviewer}" ; rr:class cmtdenormalized:Paper ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:paperID ;
        rr:objectMap [ rr:column "paperID" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:rejectedBy ;
        rr:objectMap [ rr:template "http://example.com/user/{rejectedBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:paperID ;
        rr:objectMap [ rr:column "readByMeta-Reviewer" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasAuthor ;
        rr:objectMap [ rr:template "http://example.com/author/{hasAuthor}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:title ;
        rr:objectMap [ rr:column "title" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasDecision ;
        rr:objectMap [ rr:template "http://example.com/rejection/{hasDecision}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:acceptedBy ;
        rr:objectMap [ rr:template "http://example.com/user/{acceptedBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasDecision ;
        rr:objectMap [ rr:template "http://example.com/document/{ID}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:readByReviewer ;
        rr:objectMap [ rr:template "http://example.com/person/{Reviewer}" ]
    ] .

# === Person (SE) ===
<#PersonMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"name\" , \"email\" , \"assignedByReviewer\" , \"TYPE\" FROM \"Person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized:Person ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:email ;
        rr:objectMap [ rr:column "email" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:email ;
        rr:objectMap [ rr:column "assignedByReviewer" ; rr:datatype xsd:string ]
    ] .

# === Preference (SE) ===
<#PreferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Preference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/preference/{ID}" ; rr:class cmtdenormalized:Preference ] .

