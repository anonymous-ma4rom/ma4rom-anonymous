<#ProgramCommitteeMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"ProgramCommittee\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/programcommittee/{ID}" ; rr:class cmtdenormalized:ProgramCommittee ] .

# === Rejection (SE) ===
<#RejectionMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Rejection\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/rejection/{ID}" ; rr:class cmtdenormalized:Rejection ] .

# === SubjectArea (SE) ===
<#SubjectAreaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"SubjectArea\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/subjectarea/{ID}" ; rr:class cmtdenormalized:SubjectArea ] .

# === markConflictOfInterest (SE) ===
<#markConflictOfInterestMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ConferenceMember\" , \"Paper\" FROM \"markConflictOfInterest\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/markconflictofinterest/{ConferenceMember}__{Paper}" ; rr:class cmtdenormalized:ProgramCommitteeChair ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:maxPapers ;
        rr:objectMap [ rr:column "Paper" ; rr:datatype xsd:int ]
    ] .

# === Document (Type Assertions) ===
<#Document_TYPE_0_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Document\" WHERE \"TYPE\" = 0" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtdenormalized:Paper ]
    ] .

<#Document_TYPE_1_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Document\" WHERE \"TYPE\" = 1" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtdenormalized:Review ]
    ] .

# === Paper (Type Assertions) ===
<#Paper_TYPE_2_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"Reviewer\" FROM \"Paper\" WHERE \"TYPE\" = 2" ] ;
    rr:subjectMap [ rr:template "http://example.com/paper/{ID}__{Reviewer}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtdenormalized:Paper ]
    ] .

# === Person (Type Assertions) ===
<#Person_TYPE_2_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"TYPE\" = 2" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtdenormalized:User ]
    ] .
