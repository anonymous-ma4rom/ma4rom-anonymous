    ] .

# === paper_subject_area (SR) ===
<#paper_subject_areaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"sid\" FROM \"paper_subject_area\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/papers/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:hasSubjectArea ;
        rr:objectMap [ rr:template "http://example.com/subject_areas/{sid}" ]
    ] .

# === person_document (SR) ===
<#person_documentMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"did\" , \"pid\" FROM \"person_document\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{did}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:runPaperAssignmentTools ;
        rr:objectMap [ rr:template "http://example.com/persons/{pid}" ]
    ] .

# === program_committee_chair_review (SR) ===
<#program_committee_chair_reviewMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"rid\" FROM \"program_committee_chair_review\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/program_committee_chairs/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:endReview ;
        rr:objectMap [ rr:template "http://example.com/reviews/{rid}" ]
    ] .

# === program_committee_members (SR) ===
<#program_committee_membersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"program_committee\" , \"program_committee_member\" FROM \"program_committee_members\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/program_committees/{program_committee}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:hasProgramCommitteeMember ;
        rr:objectMap [ rr:template "http://example.com/pc_members/{program_committee_member}" ]
    ] .

# === read_by_reviewer (SR) ===
<#read_by_reviewerMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"rid\" FROM \"read_by_reviewer\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/papers/{pid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:readByReviewer ;
        rr:objectMap [ rr:template "http://example.com/reviewers/{rid}" ]
    ] .

# === reviewer_administrator (SR) ===
<#reviewer_administratorMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"aid\" , \"rid\" FROM \"reviewer_administrator\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/administrators/{aid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:startReviewerBidding ;
        rr:objectMap [ rr:template "http://example.com/reviewers/{rid}" ]
    ] .

# === mark_conflict_interests (MV) ===
# SKIP: mark_conflict_interests (MV/OP) 无法解析 range 表

# === set_max_papers (MV) ===
# SKIP: set_max_papers (MV/OP) 无法解析 range 表

# === bids (SE) ===
<#bidsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"adjusted\" , \"bid\" FROM \"bids\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/bids/{id}" ; rr:class cmtrenamed:Bid ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:adjustedBy ;
        rr:objectMap [ rr:template "http://example.com/reviewers/{adjusted}" ]
    ] .

# === conferences (SE) ===
<#conferencesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"site_url\" , \"accepts_hardcopy_submissions\" , \"logo_url\" , \"date\" , \"name\" , \"reviews_per_paper\" FROM \"conferences\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conferences/{id}" ; rr:class cmtrenamed:Conference ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:siteURL ;
        rr:objectMap [ rr:column "site_url" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:logoURL ;
        rr:objectMap [ rr:column "logo_url" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:date ;
        rr:objectMap [ rr:column "date" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:reviewsPerPaper ;
        rr:objectMap [ rr:column "reviews_per_paper" ; rr:datatype xsd:int ]
    ] .

# === decisions (SE) ===
<#decisionsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"decisions\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/decisions/{id}" ; rr:class cmtrenamed:Decision ] .

# === documents (SE) ===
<#documentsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"documents\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{id}" ; rr:class cmtrenamed:Document ] .

# === persons (SE) ===
<#personsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"name\" , \"email\" FROM \"persons\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class cmtrenamed:Person ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:email ;
        rr:objectMap [ rr:column "email" ; rr:datatype xsd:string ]
    ] .

# === preferences (SE) ===
<#preferencesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"preferences\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/preferences/{id}" ; rr:class cmtrenamed:Preference ] .

# === program_committees (SE) ===
<#program_committeesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"label\" FROM \"program_committees\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/program_committees/{id}" ; rr:class cmtrenamed:ProgramCommittee ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:name ;
        rr:objectMap [ rr:column "label" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rr:column "label" ; rr:datatype xsd:string ]
    ] .

# === subject_areas (SE) ===
<#subject_areasMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"subject_areas\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/subject_areas/{id}" ; rr:class cmtrenamed:SubjectArea ] .
