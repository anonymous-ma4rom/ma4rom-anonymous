    ] .

# === paper_author (SR) ===
<#paper_authorMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"aid\" , \"pid\" FROM \"paper_author\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/authors/{aid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:submitPaper ;
        rr:objectMap [ rr:template "http://example.com/papers/{pid}" ]
    ] .

# === paper_reviewer (SR) ===
<#paper_reviewerMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"pid\" , \"rid\" FROM \"paper_reviewer\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/papers/{pid}" ] ;
    rr:predicateObjectMap [
