@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtrenamed: <http://cmt#> .
@base <http://example.com/> .

# === administrator_conference (SR) ===
<#administrator_conferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"aid\" , \"cid\" FROM \"administrator_conference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/administrators/{aid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:enterConferenceDetails ;
        rr:objectMap [ rr:template "http://example.com/conferences/{cid}" ]
    ] .

# === co_author_paper (SR) ===
<#co_author_paperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"cid\" , \"pid\" FROM \"co_author_paper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/co_authors/{cid}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://cmt#co-writePaper> ;
        rr:objectMap [ rr:template "http://example.com/papers/{pid}" ]
    ] .

# === conference_administrator (SR) ===
<#conference_administratorMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"cid\" , \"aid\" FROM \"conference_administrator\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conferences/{cid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:paperAssignmentToolsRunBy ;
        rr:objectMap [ rr:template "http://example.com/administrators/{aid}" ]
    ] .

# === conference_members (SR) ===
<#conference_membersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"conference\" , \"conference_member\" FROM \"conference_members\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conferences/{conference}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:hasConferenceMember ;
        rr:objectMap [ rr:template "http://example.com/reviewers/{conference_member}" ]
    ] .

# === details_entered (SR) ===
<#details_enteredMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"aid\" , \"cid\" FROM \"details_entered\"" ] ;
