<#paper_assignment_tools_runMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"cid\" , \"aid\" FROM \"paper_assignment_tools_run\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conferences/{cid}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:paperAssignmentToolsRunBy ;
