conferencestructured:	http://conference#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping--1743658201
target		<http://example.com/important_dates/{ID}> a conferencestructured:Important_dates ; conferencestructured:is_a_date_of_acceptance_announcement {is_a_date_of_acceptance_a}^^xsd:date ; conferencestructured:is_an_abstract_submission_date {is_an_abstract_submission}^^xsd:date ; conferencestructured:is_a_date_of_camera_ready_paper_submission {is_a_date_of_camera_ready}^^xsd:date ; conferencestructured:is_a_full_paper_submission_date {is_a_full_paper_submissio}^^xsd:date ; conferencestructured:is_an_ending_date {is_an_ending_date}^^xsd:date ; conferencestructured:is_a_starting_date {is_a_starting_date}^^xsd:date . 
source		SELECT "ID" , "is_a_date_of_acceptance_a" , "is_a_full_paper_submissio" , "is_a_date_of_camera_ready" , "is_an_ending_date" , "is_a_starting_date" , "is_an_abstract_submission" FROM "Important_dates"

mappingId	mapping-1123090586
target		<http://example.com/conference_proceedings/{ID}> a conferencestructured:Conference_proceedings ; conferencestructured:has_a_volume {has_a_volume}^^xsd:int ; conferencestructured:has_an_ISBN {has_an_ISBN}^^xsd:string ; conferencestructured:has_a_name {has_a_name}^^xsd:string ; conferencestructured:has_a_publisher <http://example.com/publisher/{has_a_publisher}> . 
source		SELECT "ID" , "has_a_publisher" , "has_a_volume" , "has_a_name" , "has_an_ISBN" FROM "Conference_proceedings"

mappingId	mapping-223714901
target		<http://example.com/conference_document/{ID}> a conferencestructured:Conference_document ; conferencestructured:has_a_URL {has_a_URL}^^xsd:string ; conferencestructured:has_a_date_of_issue {has_a_date_of_issue}^^xsd:date . 
source		SELECT "ID" , "has_a_date_of_issue" , "has_a_URL" , "TYPE" FROM "Conference_document"

mappingId	mapping-1536934482
target		<http://example.com/organizer/{ID}> a conferencestructured:Organizer . 
source		SELECT "ID" FROM "Organizer"

mappingId	mapping--609027288
target		<http://example.com/person/{ID}> a conferencestructured:Contribution_1th-author . 
