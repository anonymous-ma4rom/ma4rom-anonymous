mappingId	mapping-250507652
target		<http://example.com/person/{ID}> a conferencestructured:Person ; conferencestructured:has_the_last_name {has_the_last_name}^^xsd:string ; conferencestructured:has_the_first_name {has_the_first_name}^^xsd:string ; conferencestructured:has_gender {has_gender}^^xsd:string . 
source		SELECT "ID" , "has_the_first_name" , "has_the_last_name" , "has_gender" , "is_Conference_contributor" , "is_Contribution_co-author" , "is_Committee_member" , "is_Chair" , "is_Contribution_1th-author" , "is_Reviewer" , "TYPE" FROM "Person"

