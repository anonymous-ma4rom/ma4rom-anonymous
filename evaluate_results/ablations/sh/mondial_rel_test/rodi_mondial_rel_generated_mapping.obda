[MappingDeclaration] @collection [[
mappingId	mapping--581966744
target		<http://example.com/sea/{name}> a mondialrel:Sea ; mondialrel:name {name}^^xsd:string ; mondialrel:depth {depth}^^xsd:decimal . 
source		SELECT "name" , "depth" FROM "sea"

mappingId	mapping--907363280
target		<http://example.com/island/{name}> a mondialrel:Island ; mondialrel:name {name}^^xsd:string ; mondialrel:elevation {elevation}^^xsd:decimal ; mondialrel:area {area}^^xsd:decimal . 
