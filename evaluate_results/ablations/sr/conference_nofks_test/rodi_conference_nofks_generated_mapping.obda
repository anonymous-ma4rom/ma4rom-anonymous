[MappingDeclaration] @collection [[
mappingId	mapping-80752048
target		<http://example.com/important_dates/{ID}> a conferencenofks:Important_dates ; conferencenofks:is_a_date_of_camera_ready_paper_submission {is_a_date_of_camera_ready}^^xsd:date ; conferencenofks:is_a_full_paper_submission_date {is_a_full_paper_submissio}^^xsd:date ; conferencenofks:is_an_ending_date {is_an_ending_date}^^xsd:date ; conferencenofks:is_a_starting_date {is_a_starting_date}^^xsd:date ; conferencenofks:is_a_date_of_acceptance_announcement {is_a_date_of_acceptance_a}^^xsd:date ; conferencenofks:is_an_abstract_submission_date {is_an_abstract_submission}^^xsd:date . 
source		SELECT "ID" , "is_a_date_of_acceptance_a" , "is_a_full_paper_submissio" , "is_a_date_of_camera_ready" , "is_an_ending_date" , "is_a_starting_date" , "is_an_abstract_submission" FROM "Important_dates"

mappingId	mapping-1728841762
target		<http://example.com/conference_proceedings/{ID}> a conferencenofks:Conference_proceedings ; conferencenofks:has_a_name {has_a_name}^^xsd:string ; conferencenofks:has_a_volume {has_a_volume}^^xsd:int , {has_a_publisher}^^xsd:int ; conferencenofks:has_an_ISBN {has_an_ISBN}^^xsd:string . 
source		SELECT "ID" , "has_a_publisher" , "has_a_volume" , "has_a_name" , "has_an_ISBN" FROM "Conference_proceedings"

mappingId	mapping-829049742
target		<http://example.com/paper/{ID}> a conferencenofks:Paper ; conferencenofks:has_an_abstract <http://example.com/abstract/{has_an_abstract}> ; conferencenofks:is_submitted_at <http://example.com/conference_volume/{is_submitted_at}> ; conferencenofks:has_a_paper_title {has_a_paper_title}^^xsd:string . 
source		SELECT "ID" , "has_an_abstract" , "has_a_paper_title" , "is_submitted_at" , "TYPE" FROM "Paper"

mappingId	mapping-644097295
target		<http://example.com/conference_document/{ID}> a conferencenofks:Conference_document ; conferencenofks:has_a_URL {has_a_URL}^^xsd:string ; conferencenofks:has_a_date_of_issue {has_a_date_of_issue}^^xsd:date . 
