mappingId	mapping--1377368483
target		<http://example.com/person/{ID}> a conferencenofks:Person ; conferencenofks:has_the_last_name {has_the_last_name}^^xsd:string ; conferencenofks:has_gender {has_gender}^^xsd:string ; conferencenofks:has_the_first_name {has_the_first_name}^^xsd:string . 
