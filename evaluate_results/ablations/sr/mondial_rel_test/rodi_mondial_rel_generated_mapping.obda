[MappingDeclaration] @collection [[
mappingId	mapping--1412242395
target		<http://example.com/sea/{name}> a mondialrel:Sea ; mondialrel:name {name}^^xsd:string ; mondialrel:depth {depth}^^xsd:decimal . 
source		SELECT "name" , "depth" FROM "sea"

mappingId	mapping-640297200
target		<http://example.com/island/{name}> a mondialrel:Island ; mondialrel:elevation {elevation}^^xsd:decimal ; mondialrel:area {area}^^xsd:decimal ; mondialrel:name {name}^^xsd:string . 
source		SELECT "name" , "islands" , "area" , "elevation" , "type" , "coordinates" FROM "island"

mappingId	mapping--924820086
target		<http://example.com/country/{country}> a mondialrel:Country ; mondialrel:gdpAgri {agriculture}^^xsd:decimal ; mondialrel:gdpTotal {gdp}^^xsd:decimal ; mondialrel:gdpInd {industry}^^xsd:decimal ; mondialrel:gdpServ {service}^^xsd:decimal ; mondialrel:inflation {inflation}^^xsd:decimal ; mondialrel:unemployment {unemployment}^^xsd:decimal . 
source		SELECT "country" , "gdp" , "agriculture" , "service" , "industry" , "inflation" , "unemployment" FROM "economy"

mappingId	mapping-1742245849
target		<http://example.com/ismember/{country}__{organization}> a mondialrel:Membership . 
