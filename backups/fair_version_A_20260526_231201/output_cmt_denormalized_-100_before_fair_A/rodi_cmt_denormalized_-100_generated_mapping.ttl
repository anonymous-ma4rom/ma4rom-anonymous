    ] .

# === hardcopyMailingManifestsP (SR) ===
<#hardcopyMailingManifestsPMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference\" , \"Administrator\" FROM \"hardcopyMailingManifestsP\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{Conference}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:hardcopyMailingManifestsPrintedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{Administrator}" ]
    ] .

