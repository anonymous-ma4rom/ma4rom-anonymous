    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference\" , \"Administrator\" FROM \"enableVirtualMeeting\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{Conference}" ] ;
