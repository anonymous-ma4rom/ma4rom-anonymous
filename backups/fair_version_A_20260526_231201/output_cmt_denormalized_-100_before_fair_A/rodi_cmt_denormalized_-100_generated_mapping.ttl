@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtdenormalized-100: <http://cmt#> .
@base <http://example.com/> .

# === Author (SH) ===
<#AuthorMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"TYPE\" FROM \"Author\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] .

# === Paper (SH) ===
<#PaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"paperID\" , \"rejectedBy\" , \"readByMeta-Reviewer\" , \"hasAuthor\" , \"title\" , \"hasDecision\" , \"acceptedBy\" , \"TYPE\" , \"Reviewer\" FROM \"Paper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:paperID ;
        rr:objectMap [ rr:column "paperID" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:rejectedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{rejectedBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://cmt#readByMeta-Reviewer> ;
        rr:objectMap [ rr:template "http://example.com/person/{readByMeta-Reviewer}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:hasAuthor ;
        rr:objectMap [ rr:template "http://example.com/person/{hasAuthor}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:title ;
        rr:objectMap [ rr:column "title" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:paperID ;
        rr:objectMap [ rr:column "hasDecision" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:acceptedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{acceptedBy}" ]
    ] .

# === ProgramCommitteeChair (SH) ===
<#ProgramCommitteeChairMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"ProgramCommitteeChair\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized-100:ProgramCommitteeChair ] .

# === ProgramCommitteeMember (SH) ===
<#ProgramCommitteeMemberMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"maxPapers\" , \"addedBy\" FROM \"ProgramCommitteeMember\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized-100:ProgramCommitteeMember ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:maxPapers ;
        rr:objectMap [ rr:column "maxPapers" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:addedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{addedBy}" ]
    ] .

# === User (SH) ===
<#UserMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"acceptPaper\" , \"TYPE\" FROM \"User\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] .

# === co-writePaper (SR) ===
<#co-writePaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Co-author\" , \"Paper\" FROM \"co-writePaper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Co-author}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://cmt#co-writePaper> ;
        rr:objectMap [ rr:template "http://example.com/document/{Paper}" ]
    ] .

# === detailsEnteredBy (SR) ===
<#detailsEnteredByMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference\" , \"Administrator\" FROM \"detailsEnteredBy\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{Conference}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:detailsEnteredBy ;
        rr:objectMap [ rr:template "http://example.com/person/{Administrator}" ]
    ] .

