<#setMaxPapersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ProgramCommitteeMember\" , \"Administrator\" FROM \"setMaxPapers\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ProgramCommitteeMember}" ] ;
