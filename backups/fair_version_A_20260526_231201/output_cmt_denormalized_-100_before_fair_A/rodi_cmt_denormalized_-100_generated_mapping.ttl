# === Bid (SE) ===
<#BidMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"adjustedBy\" , \"hasBid_Inv\" FROM \"Bid\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/bid/{ID}" ; rr:class cmtdenormalized-100:Bid ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:adjustedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{adjustedBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:hasBid ;
        rr:objectMap [ rr:template "http://example.com/submitpaper/{hasBid_Inv}" ]
    ] .

# === Conference (SE) ===
<#ConferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"siteURL\" , \"acceptsHardcopySubmissions\" , \"logoURL\" , \"date\" , \"name\" , \"reviewsPerPaper\" FROM \"Conference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{ID}" ; rr:class cmtdenormalized-100:Conference ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:siteURL ;
        rr:objectMap [ rr:column "siteURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:logoURL ;
        rr:objectMap [ rr:column "logoURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:date ;
        rr:objectMap [ rr:column "date" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:reviewsPerPaper ;
        rr:objectMap [ rr:column "reviewsPerPaper" ; rr:datatype xsd:int ]
    ] .

