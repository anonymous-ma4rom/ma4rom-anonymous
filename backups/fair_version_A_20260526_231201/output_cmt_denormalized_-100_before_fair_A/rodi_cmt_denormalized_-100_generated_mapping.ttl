<#PersonMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"name\" , \"email\" , \"assignedByReviewer\" , \"TYPE\" FROM \"Person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized-100:Person ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:email ;
        rr:objectMap [ rr:column "email" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized-100:assignedByReviewer ;
        rr:objectMap [ rr:template "http://example.com/person/{assignedByReviewer}" ]
    ] .

