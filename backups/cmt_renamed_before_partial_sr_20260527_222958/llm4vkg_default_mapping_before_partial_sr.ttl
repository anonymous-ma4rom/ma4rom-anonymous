@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtrenamed: <http://cmt#> .
@base <http://example.com/> .

# === acceptances (SH) ===
<#acceptancesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"acceptances\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/decisions/{id}" ; rr:class cmtrenamed:Acceptance ] .

# === administrators (SH) ===
<#administratorsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"accept_paper\" FROM \"administrators\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class cmtrenamed:Administrator ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed:acceptPaper ;
        rr:objectMap [ rr:template "http://example.com/documents/{accept_paper}" ]
    ] .

# === associated_chairs (SH) ===
<#associated_chairsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"associated_chairs\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class cmtrenamed:AssociatedChair ] .

# === author_not_reviewers (SH) ===
<#author_not_reviewersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"author_not_reviewers\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class cmtrenamed:AuthorNotReviewer ] .

# === authors (SH) ===
<#authorsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"authors\"" ] ;
