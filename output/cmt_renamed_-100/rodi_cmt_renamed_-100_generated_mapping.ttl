@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtrenamed-100: <http://cmt#> .
@base <http://example.com/> .

# === authors (SH) ===
<#authorsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"authors\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class cmtrenamed-100:Author ] .

# === chairmans (SH) ===
<#chairmansMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"chairmans\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class cmtrenamed-100:Chairman ] .

# === co_authors (SH) ===
<#co_authorsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"co_authors\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class <http://cmt#Co-author> ] .

# === meta_reviewers (SH) ===
<#meta_reviewersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"meta_reviewers\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/meta_reviews/{id}" ; rr:class <http://cmt#Meta-Reviewer> ] .

# === paper_abstracts (SH) ===
<#paper_abstractsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"paper_abstracts\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{id}" ; rr:class cmtrenamed-100:PaperAbstract ] .

# === paper_full_versions (SH) ===
<#paper_full_versionsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"paper_full_versions\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{id}" ; rr:class cmtrenamed-100:PaperFullVersion ] .

# === papers (SH) ===
<#papersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"paper_id\" , \"rejected\" , \"read_by_meta_reviewer\" , \"author\" , \"title\" , \"decision\" , \"accepted\" FROM \"papers\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{id}" ; rr:class cmtrenamed-100:Paper ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:paperID ;
        rr:objectMap [ rr:column "paper_id" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:paperid ;
        rr:objectMap [ rr:column "paper_id" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:rejectedBy ;
        rr:objectMap [ rr:template "http://example.com/administrators/{rejected}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://cmt#readByMeta-Reviewer> ;
        rr:objectMap [ rr:template "http://example.com/meta_reviews/{read_by_meta_reviewer}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:hasAuthor ;
        rr:objectMap [ rr:template "http://example.com/persons/{author}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:title ;
        rr:objectMap [ rr:column "title" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:paperID ;
        rr:objectMap [ rr:column "decision" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:paperid ;
        rr:objectMap [ rr:column "decision" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtrenamed-100:acceptedBy ;
        rr:objectMap [ rr:template "http://example.com/administrators/{accepted}" ]
    ] .

