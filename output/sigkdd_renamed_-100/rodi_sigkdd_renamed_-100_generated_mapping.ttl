<#sponzorsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"name_sponsor\" FROM \"sponzors\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/sponzors/{id}" ; rr:class sigkddrenamed-100:Sponzor ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddrenamed-100:Name_of_sponsor ;
        rr:objectMap [ rr:column "name_sponsor" ; rr:datatype xsd:string ]
    ] .

# === webmasters (SE) ===
<#webmastersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"webmasters\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/webmasters/{id}" ; rr:class sigkddrenamed-100:Webmaster ] .
