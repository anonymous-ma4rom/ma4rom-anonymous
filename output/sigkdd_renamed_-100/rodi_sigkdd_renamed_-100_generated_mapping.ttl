@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sigkddrenamed-100: <http://sigkdd#> .
@base <http://example.com/> .

# === abstracts (SH) ===
<#abstractsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"title\" FROM \"abstracts\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{id}" ; rr:class sigkddrenamed-100:Abstract ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddrenamed-100:hasTitle ;
        rr:objectMap [ rr:column "title" ; rr:datatype xsd:string ]
    ] .

# === authors (SH) ===
<#authorsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"authors\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class sigkddrenamed-100:Author ] .

