mappingId	mapping-1211744974
target		<http://example.com/acm_sigkdd/{ID}> a sigkddstructured:ACM_SIGKDD . 
source		SELECT "ID" FROM "ACM_SIGKDD"

mappingId	mapping--1044514867
target		<http://example.com/document/{ID}> a sigkddstructured:Document ; sigkddstructured:hasTitle {hasTitle}^^xsd:string . 
source		SELECT "ID" , "hasTitle" , "TYPE" FROM "Document"

mappingId	mapping--2077921729
target		<http://example.com/conference/{ID}> a sigkddstructured:Conference ; sigkddstructured:Start_of_conference {Start_of_conference}^^xsd:dateTime ; sigkddstructured:City_of_conference {City_of_conference}^^xsd:string ; sigkddstructured:Name_of_conference {Name_of_conference}^^xsd:string ; sigkddstructured:End_of_conference {End_of_conference}^^xsd:dateTime ; sigkddstructured:holded_by <http://example.com/acm_sigkdd/{holded_by}> . 
source		SELECT "ID" , "holded_by" , "Start_of_conference" , "City_of_conference" , "Name_of_conference" , "End_of_conference" FROM "Conference"

mappingId	mapping-811775654
target		<http://example.com/document/{ID}> a sigkddstructured:Paper . 
source		SELECT "ID" FROM "Document" WHERE "TYPE" = 1

mappingId	mapping--1522942537
target		<http://example.com/person/{ID}> a sigkddstructured:Program_Chair . 
source		SELECT "ID" FROM "Person" WHERE "is_Program_Chair" = true

mappingId	mapping-1723411167
target		<http://example.com/best_paper_awards_committ/{ID}> a sigkddstructured:Best_Paper_Awards_Committee ; sigkddstructured:award <http://example.com/best_research_paper_award/{award}> ; sigkddstructured:isCommitteeOf <http://example.com/conference/{hasCommittee_Inv}> , <http://example.com/conference/{isCommitteeOf}> . 
source		SELECT "ID" , "award" , "hasCommittee_Inv" , "isCommitteeOf" FROM "Best_Paper_Awards_Committ"

mappingId	mapping--1343359793
target		<http://example.com/registration_fee/{ID}> a sigkddstructured:Registration_fee . 
source		SELECT "ID" FROM "Registration_fee" WHERE "TYPE" = 0

mappingId	mapping--749685402
target		<http://example.com/program_committee/{ID}> a sigkddstructured:Program_Committee ; rdfs:label {label}^^xsd:string ; sigkddstructured:isCommitteeOf <http://example.com/conference/{hasCommittee_Inv}> , <http://example.com/conference/{isCommitteeOf}> ; sigkddstructured:Name {label}^^xsd:string . 
source		SELECT "ID" , "label" , "hasCommittee_Inv" , "isCommitteeOf" FROM "Program_Committee"

mappingId	mapping--587192432
target		<http://example.com/document/{ID}> a sigkddstructured:Review ; sigkddstructured:hasText {hasText}^^xsd:string ; sigkddstructured:hasID {hasID}^^xsd:int ; sigkddstructured:hasid {hasID}^^xsd:int ; sigkddstructured:isReviewOf <http://example.com/document/{hasReview_Inv}> , <http://example.com/document/{isReviewOf}> . 
source		SELECT "ID" , "hasReview_Inv" , "isReviewOf" , "hasID" , "hasText" FROM "Review"

mappingId	mapping-1024733558
target		<http://example.com/person/{ID}> a sigkddstructured:Organizator . 
source		SELECT "ID" FROM "Person" WHERE "is_Organizator" = true
]]

