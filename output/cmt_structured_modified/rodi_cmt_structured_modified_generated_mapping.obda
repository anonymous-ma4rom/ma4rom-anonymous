mappingId	mapping--426805445
target		<http://example.com/person/{ID}> a cmtstructuredmodified:ProgramCommitteeMember ; cmtstructuredmodified:addedBy <http://example.com/person/{addedBy}> ; cmtstructuredmodified:maxPapers {maxPapers}^^xsd:int . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeMember"

mappingId	mapping-1996987911
target		<http://example.com/document/{ID}> a cmtstructuredmodified:Review ; cmtstructuredmodified:writtenBy <http://example.com/person/{writtenBy}> ; rdfs:comment {comment}^^xsd:string . 
source		SELECT "ID" , "writtenBy" , "comment" , "TYPE" FROM "Review"
]]

