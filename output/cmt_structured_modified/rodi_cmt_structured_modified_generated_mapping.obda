[PrefixDeclaration]
rr:		http://www.w3.org/ns/r2rml#
rdf:		http://www.w3.org/1999/02/22-rdf-syntax-ns#
rdfs:		http://www.w3.org/2000/01/rdf-schema#
xsd:		http://www.w3.org/2001/XMLSchema#
cmtstructuredmodified:	http://cmt#
owl:		http://www.w3.org/2002/07/owl#
obda:		https://w3id.org/obda/vocabulary#

[MappingDeclaration] @collection [[
mappingId	mapping-171006802
target		<http://example.com/acceptance/{ID}> a cmtstructuredmodified:Acceptance . 
source		SELECT "ID" , "TYPE" FROM "Acceptance"

mappingId	mapping--907902526
target		<http://example.com/person/{Administrator}> cmtstructuredmodified:enterReviewCriteria <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "enterReviewCriteria"

mappingId	mapping--349048248
target		<http://example.com/document/{ID}> cmtstructuredmodified:rejectedBy <http://example.com/person/{rejectedBy}> ; cmtstructuredmodified:readByMeta-Reviewer <http://example.com/person/{readByMeta-Reviewer}> ; cmtstructuredmodified:paperID {paperID}^^xsd:unsignedLong ; cmtstructuredmodified:hasAuthor <http://example.com/person/{R2}> ; cmtstructuredmodified:title {VALUE}^^xsd:string ; cmtstructuredmodified:hasDecision <http://example.com/acceptance/{hasDecision}> ; cmtstructuredmodified:paperid {paperID}^^xsd:unsignedLong ; cmtstructuredmodified:acceptedBy <http://example.com/person/{acceptedBy}> . 
source		SELECT "ID" , "paperID" , "rejectedBy" , "readByMeta-Reviewer" , "R2" , "VALUE" , "hasDecision" , "acceptedBy" , "TYPE" FROM "Paper"

mappingId	mapping--1543318422
target		<http://example.com/person/{ID}> a cmtstructuredmodified:Person ; cmtstructuredmodified:name {name}^^xsd:string ; cmtstructuredmodified:email {email}^^xsd:string ; cmtstructuredmodified:assignedByReviewer <http://example.com/person/{assignedByReviewer}> . 
source		SELECT "ID" , "name" , "email" , "is_user" , "assignedByReviewer" , "is_Reviewer" , "is_Author" , "is_Co-author" , "TYPE" FROM "Person"

mappingId	mapping-129885121
target		<http://example.com/person/{Author}> cmtstructuredmodified:submitPaper <http://example.com/document/{Paper}> . 
source		SELECT "Author" , "Paper" FROM "submitPaper"

mappingId	mapping--333130879
target		<http://example.com/conference/{Conference}> cmtstructuredmodified:hasConferenceMember <http://example.com/person/{ConferenceMember}> . 
source		SELECT "Conference" , "ConferenceMember" FROM "hasConferenceMember"

mappingId	mapping-1597373624
target		<http://example.com/document/{Paper}> cmtstructuredmodified:readByReviewer <http://example.com/person/{Reviewer}> . 
source		SELECT "Paper" , "Reviewer" FROM "readByReviewer"

mappingId	mapping-1831188773
target		<http://example.com/person/{ID}> a cmtstructuredmodified:Author . 
source		SELECT "ID" FROM "Person" WHERE "is_Author" = true

mappingId	mapping-839213574
target		<http://example.com/subjectarea/{ID}> a cmtstructuredmodified:SubjectArea . 
source		SELECT "ID" FROM "SubjectArea"

mappingId	mapping--804993437
target		<http://example.com/person/{ID}> a cmtstructuredmodified:Administrator ; cmtstructuredmodified:acceptPaper <http://example.com/document/{acceptPaper}> . 
source		SELECT "ID" , "acceptPaper" FROM "Administrator"

mappingId	mapping-1766086012
target		<http://example.com/person/{ProgramCommitteeChair}> cmtstructuredmodified:endReview <http://example.com/document/{Review}> . 
source		SELECT "ProgramCommitteeChair" , "Review" FROM "endReview"

mappingId	mapping--2000556018
target		<http://example.com/document/{Paper}> cmtstructuredmodified:assignedTo <http://example.com/person/{Reviewer}> . 
source		SELECT "Paper" , "Reviewer" FROM "R1"

mappingId	mapping-1701756829
target		<http://example.com/bid/{ID}> a cmtstructuredmodified:Bid ; cmtstructuredmodified:adjustedBy <http://example.com/person/{adjustedBy}> . 
source		SELECT "ID" , "adjustedBy" , "hasBid_Inv" FROM "Bid"

mappingId	mapping--2111890888
target		<http://example.com/programcommittee/{ID}> a cmtstructuredmodified:ProgramCommittee ; cmtstructuredmodified:name {label}^^xsd:string ; rdfs:label {label}^^xsd:string . 
source		SELECT "ID" , "label" FROM "ProgramCommittee"

mappingId	mapping-567195576
target		<http://example.com/person/{Administrator}> cmtstructuredmodified:finalizePaperAssignment <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "finalizePaperAssignment"

