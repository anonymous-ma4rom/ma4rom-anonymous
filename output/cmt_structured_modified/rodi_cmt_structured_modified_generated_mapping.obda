target		<http://example.com/document/{Paper}> cmtstructuredmodified:hasSubjectArea <http://example.com/subjectarea/{SubjectArea}> . 
source		SELECT "Paper" , "SubjectArea" FROM "hasSubjectArea"

mappingId	mapping--1745789091
target		<http://example.com/person/{Co-author}> cmtstructuredmodified:co-writePaper <http://example.com/document/{Paper}> . 
source		SELECT "Co-author" , "Paper" FROM "co-writePaper"

mappingId	mapping--1493212716
target		<http://example.com/person/{ID}> a cmtstructuredmodified:ProgramCommitteeChair ; cmtstructuredmodified:maxPapers {maxPapers}^^xsd:int ; cmtstructuredmodified:addedBy <http://example.com/person/{addedBy}> . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeChair"

