mappingId	mapping-1449952762
target		<http://example.com/document/{ID}> a cmtstructuredmodified:Review . 
source		SELECT "ID" FROM "Review" WHERE "TYPE" = 0

mappingId	mapping--955903862
target		<http://example.com/person/{ID}> a cmtstructuredmodified:Reviewer . 
source		SELECT "ID" FROM "Person" WHERE "is_Reviewer" = true

mappingId	mapping--374018906
target		<http://example.com/conference/{Conference}> cmtstructuredmodified:detailsEnteredBy <http://example.com/person/{Administrator}> . 
source		SELECT "Conference" , "Administrator" FROM "detailsEnteredBy"

mappingId	mapping--1709231719
target		<http://example.com/person/{Administrator}> cmtstructuredmodified:enableVirtualMeeting <http://example.com/conference/{Conference}> . 
source		SELECT "Administrator" , "Conference" FROM "enableVirtualMeeting"

mappingId	mapping--1084945936
target		<http://example.com/preference/{ID}> a cmtstructuredmodified:Preference . 
source		SELECT "ID" FROM "Preference"

mappingId	mapping-1264320337
target		<http://example.com/conference/{Conference}> cmtstructuredmodified:reviewerBiddingStartedBy <http://example.com/person/{Administrator}> . 
