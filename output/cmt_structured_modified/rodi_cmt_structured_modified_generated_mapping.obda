mappingId	mapping-1662510808
target		<http://example.com/person/{Person}> cmtstructuredmodified:hasConflictOfInterest <http://example.com/document/{Document}> . 
source		SELECT "Person" , "Document" FROM "hasConflictOfInterest"

mappingId	mapping-1499902254
target		<http://example.com/document/{ID}> a cmtstructuredmodified:Document . 
source		SELECT "ID" FROM "Document"

mappingId	mapping-1645976468
target		<http://example.com/conference/{ID}> a cmtstructuredmodified:Conference ; cmtstructuredmodified:logourl {logoURL}^^xsd:anyURI ; cmtstructuredmodified:reviewsPerPaper {reviewsPerPaper}^^xsd:int ; cmtstructuredmodified:siteurl {siteURL}^^xsd:anyURI ; cmtstructuredmodified:logoURL {logoURL}^^xsd:anyURI ; cmtstructuredmodified:date {date}^^xsd:date ; cmtstructuredmodified:name {name}^^xsd:string ; cmtstructuredmodified:siteURL {siteURL}^^xsd:anyURI . 
source		SELECT "ID" , "siteURL" , "acceptsHardcopySubmissions" , "logoURL" , "date" , "name" , "reviewsPerPaper" FROM "Conference"

mappingId	mapping-1027846818
target		<http://example.com/document/{ID}> a cmtstructuredmodified:PaperFullVersion . 
source		SELECT "ID" FROM "Paper" WHERE "TYPE" = 1

mappingId	mapping--1281009
target		<http://example.com/conference/{Conference}> cmtstructuredmodified:hardcopyMailingManifestsPrintedBy <http://example.com/person/{Administrator}> . 
source		SELECT "Conference" , "Administrator" FROM "hardcopyMailingManifestsP"

mappingId	mapping-1187134920
target		<http://example.com/document/{ID}> a cmtstructuredmodified:PaperAbstract . 
source		SELECT "ID" FROM "Paper" WHERE "TYPE" = 2

mappingId	mapping--702178069
target		<http://example.com/person/{ID}> a cmtstructuredmodified:Co-author . 
source		SELECT "ID" FROM "Person" WHERE "is_Co-author" = true

mappingId	mapping-1001582812
target		<http://example.com/conference/{Conference}> cmtstructuredmodified:paperAssignmentToolsRunBy <http://example.com/person/{Administrator}> . 
