    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"TYPE\" FROM \"Acceptance\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/acceptance/{ID}" ; rr:class cmtstructuredmodified:Acceptance ] .

# === Bid (SE) ===
<#BidMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"adjustedBy\" , \"hasBid_Inv\" FROM \"Bid\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/bid/{ID}" ; rr:class cmtstructuredmodified:Bid ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:adjustedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{adjustedBy}" ]
    ] .

# === Conference (SE) ===
<#ConferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"siteURL\" , \"acceptsHardcopySubmissions\" , \"logoURL\" , \"date\" , \"name\" , \"reviewsPerPaper\" FROM \"Conference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{ID}" ; rr:class cmtstructuredmodified:Conference ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:siteURL ;
        rr:objectMap [ rr:column "siteURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:siteurl ;
        rr:objectMap [ rr:column "siteURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:logoURL ;
        rr:objectMap [ rr:column "logoURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:logourl ;
        rr:objectMap [ rr:column "logoURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:date ;
        rr:objectMap [ rr:column "date" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:reviewsPerPaper ;
        rr:objectMap [ rr:column "reviewsPerPaper" ; rr:datatype xsd:int ]
    ] .

# === Document (SE) ===
<#DocumentMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Document\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ; rr:class cmtstructuredmodified:Document ] .

# === Person (SE) ===
<#PersonMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"name\" , \"email\" , \"is_user\" , \"assignedByReviewer\" , \"is_Reviewer\" , \"is_Author\" , \"is_Co-author\" , \"TYPE\" FROM \"Person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtstructuredmodified:Person ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:email ;
        rr:objectMap [ rr:column "email" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:assignedByReviewer ;
        rr:objectMap [ rr:template "http://example.com/person/{assignedByReviewer}" ]
    ] .

