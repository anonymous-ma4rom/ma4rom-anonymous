    rr:subjectMap [ rr:template "http://example.com/preference/{ID}" ; rr:class cmtstructuredmodified:Preference ] .

# === ProgramCommittee (SE) ===
<#ProgramCommitteeMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"label\" FROM \"ProgramCommittee\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/programcommittee/{ID}" ; rr:class cmtstructuredmodified:ProgramCommittee ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:name ;
        rr:objectMap [ rr:column "label" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rr:column "label" ; rr:datatype xsd:string ]
    ] .

# === SubjectArea (SE) ===
<#SubjectAreaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"SubjectArea\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/subjectarea/{ID}" ; rr:class cmtstructuredmodified:SubjectArea ] .

# === Paper (Type Assertions) ===
<#Paper_TYPE_1_PaperFullVersion_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Paper\" WHERE \"TYPE\" = 1" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructuredmodified:PaperFullVersion ]
    ] .

<#Paper_TYPE_2_PaperAbstract_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Paper\" WHERE \"TYPE\" = 2" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructuredmodified:PaperAbstract ]
    ] .

# === Person (Type Assertions) ===
<#Person_is_user_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_user\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructuredmodified:User ]
    ] .

<#Person_is_Reviewer_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_Reviewer\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructuredmodified:Reviewer ]
    ] .

<#Person_is_Author_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_Author\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructuredmodified:Author ]
    ] .

<#Person_is_Co_author_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_Co-author\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant <http://cmt#Co-author> ]
    ] .

# === Review (Type Assertions) ===
<#Review_TYPE_0_Review_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Review\" WHERE \"TYPE\" = 0" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
