@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtstructuredmodified: <http://cmt#> .
@base <http://example.com/> .

# === Administrator (SH) ===
<#AdministratorMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"acceptPaper\" FROM \"Administrator\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtstructuredmodified:Administrator ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:acceptPaper ;
        rr:objectMap [ rr:template "http://example.com/document/{acceptPaper}" ]
    ] .

# === Paper (SH) ===
<#PaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"paperID\" , \"rejectedBy\" , \"readByMeta-Reviewer\" , \"R2\" , \"VALUE\" , \"hasDecision\" , \"acceptedBy\" , \"TYPE\" FROM \"Paper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:paperID ;
        rr:objectMap [ rr:column "paperID" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:paperid ;
        rr:objectMap [ rr:column "paperID" ; rr:datatype xsd:unsignedLong ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:rejectedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{rejectedBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://cmt#readByMeta-Reviewer> ;
        rr:objectMap [ rr:template "http://example.com/person/{readByMeta-Reviewer}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:hasAuthor ;
        rr:objectMap [ rr:template "http://example.com/person/{R2}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:title ;
        rr:objectMap [ rr:column "VALUE" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:hasDecision ;
        rr:objectMap [ rr:template "http://example.com/acceptance/{hasDecision}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:acceptedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{acceptedBy}" ]
    ] .

# === ProgramCommitteeChair (SH) ===
<#ProgramCommitteeChairMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"maxPapers\" , \"addedBy\" FROM \"ProgramCommitteeChair\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtstructuredmodified:ProgramCommitteeChair ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:maxPapers ;
        rr:objectMap [ rr:column "maxPapers" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:addedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{addedBy}" ]
    ] .

# === ProgramCommitteeMember (SH) ===
<#ProgramCommitteeMemberMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"maxPapers\" , \"addedBy\" FROM \"ProgramCommitteeMember\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtstructuredmodified:ProgramCommitteeMember ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:maxPapers ;
        rr:objectMap [ rr:column "maxPapers" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:addedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{addedBy}" ]
    ] .

# === Review (SH) ===
<#ReviewMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"writtenBy\" , \"comment\" , \"TYPE\" FROM \"Review\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ; rr:class cmtstructuredmodified:Review ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:writtenBy ;
        rr:objectMap [ rr:template "http://example.com/person/{writtenBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:comment ;
        rr:objectMap [ rr:column "comment" ; rr:datatype xsd:string ]
    ] .

# === R1 (SR) ===
<#R1Mapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Paper\" , \"Reviewer\" FROM \"R1\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{Paper}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructuredmodified:assignedTo ;
        rr:objectMap [ rr:template "http://example.com/person/{Reviewer}" ]
    ] .

