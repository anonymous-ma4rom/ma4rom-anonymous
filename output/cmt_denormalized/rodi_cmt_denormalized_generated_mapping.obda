mappingId	mapping--1240740870
target		<http://example.com/document/{ID}> a cmtdenormalized:PaperFullVersion . 
source		SELECT "ID" FROM "Paper" WHERE "TYPE" = 2

mappingId	mapping-1522744793
target		<http://example.com/person/{ID}> a cmtdenormalized:ProgramCommitteeMember ; cmtdenormalized:addedBy <http://example.com/user/{addedBy}> ; cmtdenormalized:maxPapers {maxPapers}^^xsd:int . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeMember"

mappingId	mapping--45146840
target		<http://example.com/programcommittee/{ProgramCommittee}> cmtdenormalized:hasProgramCommitteeMember <http://example.com/person/{ProgramCommitteeMember}> . 
source		SELECT "ProgramCommittee" , "ProgramCommitteeMember" FROM "hasProgramCommitteeMember"
]]

