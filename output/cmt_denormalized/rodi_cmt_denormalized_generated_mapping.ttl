    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Conference\" FROM \"finalizePaperAssignment\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
