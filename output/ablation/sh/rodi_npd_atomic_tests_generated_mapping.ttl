# === field (SE) ===
<#fieldMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"fldname\" , \"cmplongname\" , \"fldcurrentactivitysatus\" , \"wlbname\" , \"wlbcompletiondate\" , \"fldownerkind\" , \"fldownername\" , \"fldnpdidowner\" , \"fldnpdidfield\" , \"wlbnpdidwellbore\" , \"cmpnpdidcompany\" , \"fldfactpageurl\" , \"fldfactmapurl\" , \"flddateupdated\" , \"flddateupdatedmax\" , \"datesyncnpd\" FROM \"field\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field/{fldnpdidfield}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#Field> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "fldname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "wlbname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateWellboreCompletion> ;
        rr:objectMap [ rr:column "wlbcompletiondate" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
