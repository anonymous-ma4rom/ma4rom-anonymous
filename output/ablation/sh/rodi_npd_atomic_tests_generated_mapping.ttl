    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#drillPermit> ;
        rr:objectMap [ rr:column "fldnpdidfield" ; rr:datatype xsd:string ]
    ] .

