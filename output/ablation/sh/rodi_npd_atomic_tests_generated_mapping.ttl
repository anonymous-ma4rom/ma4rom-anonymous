# === discovery (SE) ===
<#discoveryMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"dscname\" , \"cmplongname\" , \"dsccurrentactivitystatus\" , \"dschctype\" , \"wlbname\" , \"nmaname\" , \"fldname\" , \"dscdatefrominclinfield\" , \"dscdiscoveryyear\" , \"dscresinclindiscoveryname\" , \"dscownerkind\" , \"dscownername\" , \"dscnpdiddiscovery\" , \"fldnpdidfield\" , \"wlbnpdidwellbore\" , \"dscfactpageurl\" , \"dscfactmapurl\" , \"dscdateupdated\" , \"dscdateupdatedmax\" , \"datesyncnpd\" FROM \"discovery\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/discovery/{dscnpdiddiscovery}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#Discovery> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "dscname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#sourceType> ;
        rr:objectMap [ rr:column "dschctype" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "wlbname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "nmaname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2-ptl#dateLicenceValidFrom> ;
        rr:objectMap [ rr:column "dscdatefrominclinfield" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#discoveryYear> ;
        rr:objectMap [ rr:column "dscdiscoveryyear" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#includedInField> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field/{fldnpdidfield}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#discoveryWellbore> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_exploration_all/{wlbnpdidwellbore}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#hydrocarbonType> ;
        rr:objectMap [ rr:column "dscfactmapurl" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateUpdated> ;
        rr:objectMap [ rr:column "dscdateupdated" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateUpdatedMax> ;
        rr:objectMap [ rr:column "dscdateupdatedmax" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#discoveryYear> ;
        rr:objectMap [ rr:column "dscnpdiddiscovery" ; rr:datatype xsd:integer ]
    ] .

# === discovery_reserves (SE) ===
<#discovery_reservesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"dscname\" , \"dscreservesrc\" , \"dscrecoverableoil\" , \"dscrecoverablegas\" , \"dscrecoverablengl\" , \"dscrecoverablecondensate\" , \"dscdateoffresestdisplay\" , \"dscnpdiddiscovery\" , \"dscreservesdateupdated\" , \"datesyncnpd\" FROM \"discovery_reserves\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/discovery_reserves/{dscnpdiddiscovery}__{dscreservesrc}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#DiscoveryReserve> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "dscname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableOil> ;
        rr:objectMap [ rr:column "dscrecoverableoil" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableGas> ;
        rr:objectMap [ rr:column "dscrecoverablegas" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableNGL> ;
        rr:objectMap [ rr:column "dscrecoverablengl" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#recoverableCondensate> ;
        rr:objectMap [ rr:column "dscrecoverablecondensate" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#reservesResourceClass> ;
        rr:objectMap [ rr:column "dscdateoffresestdisplay" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateResourceEstimate> ;
        rr:objectMap [ rr:column "dscreservesdateupdated" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateSyncNPD> ;
        rr:objectMap [ rr:column "datesyncnpd" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#reservesResourceClass> ;
        rr:objectMap [ rr:column "dscreservesrc" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#reservesForDiscovery> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/discovery/{dscnpdiddiscovery}" ]
    ] .

# === dscarea (SE) ===
<#dscareaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"fldnpdidfield\" , \"fldname\" , \"dscnpdiddiscovery\" , \"dscname\" , \"dscresinclindiscoveryname\" , \"dscnpdidresinclindiscovery\" , \"dscincludedinfld\" , \"dschctype\" , \"fldhctype\" , \"dsccurrentactivitystatus\" , \"fldcurrentactivitystatus\" , \"flddsclabel\" , \"dscfacturl\" , \"fldfacturl\" FROM \"dscarea\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/dscarea/{dscnpdiddiscovery}__{dschctype}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#Area> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#includedInField> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field/{fldnpdidfield}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "fldname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "dscname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#resourcesIncludedInDiscovery> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/discovery/{dscnpdidresinclindiscovery}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#facilityType> ;
        rr:objectMap [ rr:column "fldhctype" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#currentStatus> ;
        rr:objectMap [ rr:column "dsccurrentactivitystatus" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://www.w3.org/2004/02/skos/core#altLabel> ;
        rr:objectMap [ rr:column "flddsclabel" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#resourcesIncludedInDiscovery> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/discovery/{dscnpdiddiscovery}" ]
    ] .

# === facility_fixed (SE) ===
<#facility_fixedMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"fclname\" , \"fclphase\" , \"fclsurface\" , \"fclcurrentoperatorname\" , \"fclkind\" , \"fclbelongstoname\" , \"fclbelongstokind\" , \"fclbelongstos\" , \"fclstartupdate\" , \"fclgeodeticdatum\" , \"fclnsdeg\" , \"fclnsmin\" , \"fclnssec\" , \"fclnscode\" , \"fclewdeg\" , \"fclewmin\" , \"fclewsec\" , \"fclewcode\" , \"fclwaterdepth\" , \"fclfunctions\" , \"fcldesignlifetime\" , \"fclfactpageurl\" , \"fclfactmapurl\" , \"fclnpdidfacility\" , \"fcldateupdated\" , \"datesyncnpd\" FROM \"facility_fixed\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/facility_fixed/{fclnpdidfacility}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#FixedFacility> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "fclname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#designLifetime> ;
        rr:objectMap [ rr:column "fclbelongstos" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateProductionStart> ;
        rr:objectMap [ rr:column "fclstartupdate" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#geodeticDatum> ;
        rr:objectMap [ rr:column "fclgeodeticdatum" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#discoveryWellbore> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_exploration_all/{fclnsdeg}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#factMapURL> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_exploration_all/{fclnsmin}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#designLifetime> ;
        rr:objectMap [ rr:column "fclnssec" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#designLifetime> ;
        rr:objectMap [ rr:column "fclewdeg" ; rr:datatype xsd:integer ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#wellboreFormationHc> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_exploration_all/{fclewmin}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#waterDepth> ;
        rr:objectMap [ rr:column "fclewsec" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#codeEW> ;
        rr:objectMap [ rr:column "fclewcode" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
