# === field_description (SE) ===
<#field_descriptionMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"fldname\" , \"flddescriptionheading\" , \"flddescriptiontext\" , \"fldnpdidfield\" , \"flddescriptiondateupdated\" FROM \"field_description\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field_description/{fldnpdidfield}__{flddescriptionheading}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#ProductionLicence> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2-ptl#name> ;
        rr:objectMap [ rr:column "fldname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateLicenceGranted> ;
        rr:objectMap [ rr:column "flddescriptiondateupdated" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#includedInField> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field/{fldnpdidfield}" ]
    ] .

# === field_investment_yearly (SE) ===
<#field_investment_yearlyMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"prfinformationcarrier\" , \"prfyear\" , \"prfinvestmentsmillnok\" , \"prfnpdidinformationcarrier\" , \"datesyncnpd\" FROM \"field_investment_yearly\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/field_investment_yearly/{prfnpdidinformationcarrier}__{prfyear}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#FieldInvestment> ] ;
