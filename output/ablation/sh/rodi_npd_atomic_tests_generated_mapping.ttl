        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_exploration_all/{wlbnpdidwellbore}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#currentFieldOperator> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/company/{cmpnpdidcompany}" ]
