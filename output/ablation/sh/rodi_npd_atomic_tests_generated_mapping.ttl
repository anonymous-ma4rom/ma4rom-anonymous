    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/facility_moveable/{fclnpdidfacility}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#MoveableFacility> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "fclname" ; rr:datatype xsd:string ]
    ] ;
