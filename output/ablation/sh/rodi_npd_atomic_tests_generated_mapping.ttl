@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix npdatomictests: <http://def.seegrid.csiro.au/isotc211/iso19103/2005/basic#> .
@base <http://sws.ifi.uio.no/data/npd-v2/> .

# === apaareagross (SE) ===
<#apaareagrossMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"apamap_no\" , \"apaareageometry_kml_wgs84\" , \"apaareagross_id\" FROM \"apaareagross\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/apaareagross/{apaareagross_id}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#AwardArea> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#npdPageURL> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_shallow_all/{apamap_no}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#blockId> ;
        rr:objectMap [ rr:column "apaareagross_id" ; rr:datatype xsd:integer ]
    ] .

# === apaareanet (SE) ===
<#apaareanetMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"blkid\" , \"blklabel\" , \"qdrname\" , \"blkname\" , \"prvname\" , \"apaareatype\" , \"urlnpd\" , \"apaareanet_id\" FROM \"apaareanet\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/apaareanet/{apaareanet_id}__{qdrname}__{blkname}__{prvname}__{blkid}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#AwardArea> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://www.w3.org/2004/02/skos/core#altLabel> ;
        rr:objectMap [ rr:column "blklabel" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#npdPageURL> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wlbpoint/{blkid}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "qdrname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "prvname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#npdPageURL> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/wellbore_exploration_all/{apaareanet_id}" ]
    ] .

# === baaarea (SE) ===
<#baaareaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"baanpdidbsnsarrarea\" , \"baanpdidbsnsarrareapoly\" , \"baaname\" , \"baakind\" , \"baaareapolydatevalidfrom\" , \"baaareapolydatevalidto\" , \"baaareapolyactive\" , \"baadateapproved\" , \"baadatevalidfrom\" , \"baadatevalidto\" , \"baaactive\" , \"baafactpageurl\" , \"baafactmapurl\" FROM \"baaarea\"" ] ;
    rr:subjectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/baaarea/{baanpdidbsnsarrarea}__{baanpdidbsnsarrareapoly}" ; rr:class <http://sws.ifi.uio.no/vocab/npd-v2#BAAArea> ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#name> ;
        rr:objectMap [ rr:column "baaname" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateBaaAreaValidFrom> ;
        rr:objectMap [ rr:column "baaareapolydatevalidfrom" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateBaaAreaValidTo> ;
        rr:objectMap [ rr:column "baaareapolydatevalidto" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateApproved> ;
        rr:objectMap [ rr:column "baadateapproved" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateBaaAreaValidFrom> ;
        rr:objectMap [ rr:column "baadatevalidfrom" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#dateBaaAreaValidTo> ;
        rr:objectMap [ rr:column "baadatevalidto" ; rr:datatype xsd:dateTime ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sws.ifi.uio.no/vocab/npd-v2#provinceLocation> ;
        rr:objectMap [ rr:template "http://sws.ifi.uio.no/data/npd-v2/bsns_arr_area/{baanpdidbsnsarrarea}" ]
    ] .

