# === markConflictOfInterest (MV) ===
# SKIP: markConflictOfInterest (MV/OP) 无法解析 range 表

# === setMaxPapers (MV) ===
# SKIP: setMaxPapers (MV/OP) 无法解析 range 表

# === Acceptance (SE) ===
<#AcceptanceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"TYPE\" FROM \"Acceptance\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/acceptance/{ID}" ; rr:class cmtstructured:Acceptance ] .

# === Bid (SE) ===
<#BidMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"adjustedBy\" , \"hasBid_Inv\" FROM \"Bid\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/bid/{ID}" ; rr:class cmtstructured:Bid ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:adjustedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{adjustedBy}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:adjustedBy ;
        rr:objectMap [ rr:template "http://example.com/paper/{hasBid_Inv}" ]
    ] .

# === Conference (SE) ===
<#ConferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"siteURL\" , \"acceptsHardcopySubmissions\" , \"logoURL\" , \"date\" , \"name\" , \"reviewsPerPaper\" FROM \"Conference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{ID}" ; rr:class cmtstructured:Conference ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:siteURL ;
        rr:objectMap [ rr:column "siteURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:logoURL ;
        rr:objectMap [ rr:column "logoURL" ; rr:datatype xsd:anyURI ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:date ;
        rr:objectMap [ rr:column "date" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:reviewsPerPaper ;
        rr:objectMap [ rr:column "reviewsPerPaper" ; rr:datatype xsd:int ]
    ] .

# === Document (SE) ===
<#DocumentMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Document\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ; rr:class cmtstructured:Document ] .

# === Person (SE) ===
<#PersonMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"name\" , \"email\" , \"is_user\" , \"assignedByReviewer\" , \"is_Reviewer\" , \"is_Author\" , \"is_Co-author\" , \"TYPE\" FROM \"Person\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtstructured:Person ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:email ;
        rr:objectMap [ rr:column "email" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:assignedByReviewer ;
        rr:objectMap [ rr:template "http://example.com/person/{assignedByReviewer}" ]
    ] .

# === Preference (SE) ===
<#PreferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Preference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/preference/{ID}" ; rr:class cmtstructured:Preference ] .

# === ProgramCommittee (SE) ===
<#ProgramCommitteeMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"label\" FROM \"ProgramCommittee\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/programcommittee/{ID}" ; rr:class cmtstructured:ProgramCommittee ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:email ;
        rr:objectMap [ rr:column "label" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate rdfs:label ;
        rr:objectMap [ rr:column "label" ; rr:datatype xsd:string ]
    ] .

# === SubjectArea (SE) ===
<#SubjectAreaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"SubjectArea\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/subjectarea/{ID}" ; rr:class cmtstructured:SubjectArea ] .

# === Person (Type Assertions) ===
<#Person_is_user_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_user\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructured:User ]
    ] .

<#Person_is_Reviewer_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_Reviewer\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructured:Reviewer ]
    ] .

<#Person_is_Author_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_Author\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructured:Author ]
    ] .

<#Person_is_Co_author_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"is_Co-author\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant <http://cmt#Co-author> ]
    ] .

<#Person_TYPE_1_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Person\" WHERE \"TYPE\" = 1" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtstructured:Reviewer ]
    ] .
