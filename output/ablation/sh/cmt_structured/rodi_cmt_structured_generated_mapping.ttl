@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtstructured: <http://cmt#> .
@base <http://example.com/> .

# === assignReviewer (SR) ===
<#assignReviewerMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Reviewer\" FROM \"assignReviewer\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/administrator/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:assignReviewer ;
        rr:objectMap [ rr:template "http://example.com/person/{Reviewer}" ]
    ] .

# === assignedTo (SR) ===
<#assignedToMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Paper\" , \"Reviewer\" FROM \"assignedTo\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/paper/{Paper}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtstructured:assignedTo ;
        rr:objectMap [ rr:template "http://example.com/person/{Reviewer}" ]
    ] .

# === co-writePaper (SR) ===
<#co-writePaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Paper\" , \"Co-author\" FROM \"co-writePaper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/paper/{Paper}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://cmt#co-writePaper> ;
        rr:objectMap [ rr:template "http://example.com/person/{Co-author}" ]
    ] .

