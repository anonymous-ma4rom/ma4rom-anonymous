<#organizationsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"name\" FROM \"organizations\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/organizations/{id}" ; rr:class conferencerenamed:Organization ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] .

# === organizers (SE) ===
<#organizersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"organizers\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/organizers/{id}" ; rr:class conferencerenamed:Organizer ] .

# === persons (SE) ===
<#personsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"first_name\" , \"last_name\" , \"gender\" FROM \"persons\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class conferencerenamed:Person ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_the_first_name ;
        rr:objectMap [ rr:column "first_name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_the_last_name ;
        rr:objectMap [ rr:column "last_name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_gender ;
        rr:objectMap [ rr:column "gender" ; rr:datatype xsd:string ]
    ] .

# === publishers (SE) ===
<#publishersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"name\" FROM \"publishers\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/publishers/{id}" ; rr:class conferencerenamed:Publisher ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] .

# === review_expertises (SE) ===
<#review_expertisesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"expertise\" , \"submitted_contribut\" FROM \"review_expertises\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/review_expertises/{id}" ; rr:class conferencerenamed:Review_expertise ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_an_expertise ;
        rr:objectMap [ rr:column "expertise" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_submitted_contribution ;
        rr:objectMap [ rr:template "http://example.com/submitted_contributions/{submitted_contribut}" ]
    ] .

# === review_preferences (SE) ===
<#review_preferencesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"belongs_to_review_refer\" , \"degree\" , \"topic_or_submissi\" FROM \"review_preferences\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/review_preferences/{id}" ; rr:class conferencerenamed:Review_preference ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_topic_or_a_submission_contribution ;
        rr:objectMap [ rr:template "http://example.com/topics/{belongs_to_review_refer}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_degree ;
        rr:objectMap [ rr:column "degree" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_degree ;
        rr:objectMap [ rr:column "topic_or_submissi" ; rr:datatype xsd:int ]
    ] .

# === topics (SE) ===
<#topicsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"name\" FROM \"topics\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/topics/{id}" ; rr:class conferencerenamed:Topic ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] .
