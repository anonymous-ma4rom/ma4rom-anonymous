<#persons_type_0_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"type\" = 0" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddmixed:Organizator ]
    ] .

<#persons_type_2_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"type\" = 2" ] ;
