<#persons_organizator_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"organizator\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddmixed:Organizator ]
    ] .

<#persons_program_chair_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"program_chair\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddmixed:Program_Chair ]
    ] .

<#persons_listener_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"listener\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddmixed:Listener ]
    ] .

<#persons_author_paper_student_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"author_paper_student\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
