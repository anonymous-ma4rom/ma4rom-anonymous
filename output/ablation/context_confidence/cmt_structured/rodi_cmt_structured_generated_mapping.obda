mappingId	mapping-572219008
target		<http://example.com/person/{ID}> a cmtstructured:ProgramCommitteeMember ; cmtstructured:addedBy <http://example.com/person/{addedBy}> ; cmtstructured:maxPapers {maxPapers}^^xsd:int . 
source		SELECT "ID" , "maxPapers" , "addedBy" FROM "ProgramCommitteeMember"

mappingId	mapping--801131579
target		<http://example.com/document/{Paper}> cmtstructured:assignedTo <http://example.com/person/{Reviewer}> . 
source		SELECT "Paper" , "Reviewer" FROM "assignedTo"

mappingId	mapping-435815144
target		<http://example.com/document/{ID}> a cmtstructured:Review ; rdfs:comment {comment}^^xsd:string ; cmtstructured:writtenBy <http://example.com/person/{writtenBy}> . 
source		SELECT "ID" , "writtenBy" , "comment" , "TYPE" FROM "Review"

mappingId	mapping--2021580770
target		<http://example.com/programcommittee/{ProgramCommittee}> cmtstructured:hasProgramCommitteeMember <http://example.com/person/{ProgramCommitteeMember}> . 
source		SELECT "ProgramCommittee" , "ProgramCommitteeMember" FROM "hasProgramCommitteeMember"
]]

