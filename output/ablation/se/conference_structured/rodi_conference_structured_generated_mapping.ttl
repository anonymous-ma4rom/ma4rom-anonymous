@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix conferencestructured: <http://conference#> .
@base <http://example.com/> .

# === Abstract (SH) ===
<#AbstractMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"is_the_1th_part_of\" , \"has_text\" , \"is_submitted_at\" FROM \"Abstract\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ; rr:class conferencestructured:Abstract ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:is_the_1th_part_of ;
        rr:objectMap [ rr:template "http://example.com/conference_document/{is_the_1th_part_of}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_text ;
        rr:objectMap [ rr:column "has_text" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:is_submitted_at ;
        rr:objectMap [ rr:template "http://example.com/conference_volume/{is_submitted_at}" ]
    ] .

# === Invited_talk (SH) ===
<#Invited_talkMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"is_given_by\" , \"has_an_abstract\" , \"is_submitted_at\" FROM \"Invited_talk\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ; rr:class conferencestructured:Invited_talk ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:is_given_by ;
        rr:objectMap [ rr:template "http://example.com/person/{is_given_by}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_an_abstract ;
        rr:objectMap [ rr:template "http://example.com/conference_document/{has_an_abstract}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:is_submitted_at ;
        rr:objectMap [ rr:template "http://example.com/conference_volume/{is_submitted_at}" ]
    ] .

# === Organizing_committee (SH) ===
<#Organizing_committeeMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"was_an_organizing_committ\" FROM \"Organizing_committee\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/committee/{ID}" ; rr:class conferencestructured:Organizing_committee ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:was_an_organizing_committee_of ;
        rr:objectMap [ rr:template "http://example.com/conference_volume/{was_an_organizing_committ}" ]
    ] .

# === Paper (SH) ===
<#PaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"has_an_abstract\" , \"has_a_paper_title\" , \"is_submitted_at\" , \"TYPE\" FROM \"Paper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ; rr:class conferencestructured:Paper ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_an_abstract ;
        rr:objectMap [ rr:template "http://example.com/conference_document/{has_an_abstract}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_a_paper_title ;
        rr:objectMap [ rr:column "has_a_paper_title" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:is_submitted_at ;
        rr:objectMap [ rr:template "http://example.com/conference_volume/{is_submitted_at}" ]
    ] .

# === Poster (SH) ===
<#PosterMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"has_an_abstract\" , \"is_submitted_at\" FROM \"Poster\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ; rr:class conferencestructured:Poster ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_an_abstract ;
        rr:objectMap [ rr:template "http://example.com/conference_document/{has_an_abstract}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:is_submitted_at ;
        rr:objectMap [ rr:template "http://example.com/conference_volume/{is_submitted_at}" ]
    ] .

# === Review (SH) ===
<#ReviewMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"reviews\" , \"has_detailed_comments\" FROM \"Review\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ; rr:class conferencestructured:Review ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:reviews ;
        rr:objectMap [ rr:template "http://example.com/conference_document/{reviews}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_detailed_comments ;
        rr:objectMap [ rr:column "has_detailed_comments" ; rr:datatype xsd:string ]
    ] .

# === Steering_committee (SH) ===
<#Steering_committeeMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"was_a_steering_committee_\" FROM \"Steering_committee\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/committee/{ID}" ; rr:class conferencestructured:Steering_committee ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:was_a_steering_committee_of ;
        rr:objectMap [ rr:template "http://example.com/conference_volume/{was_a_steering_committee_}" ]
    ] .

# === contributes (SR) ===
<#contributesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference_document\" , \"Person\" FROM \"contributes\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{Conference_document}" ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_authors ;
        rr:objectMap [ rr:template "http://example.com/person/{Person}" ]
    ] .

# === has_a_committee_co-chair (SR) ===
<#has_a_committee_co-chairMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Committee\" , \"Co-chair\" FROM \"has_a_committee_co-chair\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/committee/{Committee}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://conference#has_a_committee_co-chair> ;
        rr:objectMap [ rr:template "http://example.com/person/{Co-chair}" ]
    ] .

# === has_a_track-workshop-tuto (SR) ===
<#has_a_track-workshop-tutoMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference_part\" , \"Topic\" FROM \"has_a_track-workshop-tuto\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/tutorial/{Conference_part}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://conference#has_a_track-workshop-tutorial_topic> ;
        rr:objectMap [ rr:template "http://example.com/topic/{Topic}" ]
    ] .

# === has_members (SR) ===
<#has_membersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Committee\" , \"Committee_member\" FROM \"has_members\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/committee/{Committee}" ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_members ;
        rr:objectMap [ rr:template "http://example.com/person/{Committee_member}" ]
    ] .

# === invited_by (SR) ===
<#invited_byMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Reviewer1\" , \"Reviewer2\" FROM \"invited_by\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Reviewer1}" ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:invited_by ;
        rr:objectMap [ rr:template "http://example.com/person/{Reviewer2}" ]
    ] .

# === belongs_to_reviewers (MV) ===
# SKIP: belongs_to_reviewers (MV/OP) 无法解析 range 表

# === has_an_email (MV) ===
<#has_an_emailMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Person\" , \"VALUE\" FROM \"has_an_email\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Person}" ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured:has_an_email ;
        rr:objectMap [ rr:column "VALUE" ; rr:datatype xsd:string ]
    ] .

# === Paper (Type Assertions) ===
<#Paper_TYPE_0_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Paper\" WHERE \"TYPE\" = 0" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant conferencestructured:Paper ]
    ] .
