# === E-mail (MV) ===
<#E-mailMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Person\" , \"VALUE\" FROM \"E-mail\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Person}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://sigkdd#E-mail> ;
        rr:objectMap [ rr:column "VALUE" ; rr:datatype xsd:string ]
    ] .
