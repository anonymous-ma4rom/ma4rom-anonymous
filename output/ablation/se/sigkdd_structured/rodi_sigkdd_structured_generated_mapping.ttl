    ] .

# === search (SR) ===
<#searchMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ACM_SIGKDD\" , \"Sponzor\" FROM \"search\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/acm_sigkdd/{ACM_SIGKDD}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:search ;
        rr:objectMap [ rr:template "http://example.com/person/{Sponzor}" ]
    ] .

