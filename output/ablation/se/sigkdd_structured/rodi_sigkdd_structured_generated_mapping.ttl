@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix sigkddstructured: <http://sigkdd#> .
@base <http://example.com/> .

# === Review (SH) ===
<#ReviewMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"hasReview_Inv\" , \"isReviewOf\" , \"hasID\" , \"hasText\" FROM \"Review\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{ID}" ; rr:class sigkddstructured:Review ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:isReviewOf ;
        rr:objectMap [ rr:template "http://example.com/document/{hasReview_Inv}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:isReviewOf ;
        rr:objectMap [ rr:template "http://example.com/document/{isReviewOf}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:hasID ;
        rr:objectMap [ rr:column "hasID" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:hasText ;
        rr:objectMap [ rr:column "hasText" ; rr:datatype xsd:string ]
    ] .

# === can_stay_in (SR) ===
<#can_stay_inMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Person\" , \"Place\" FROM \"can_stay_in\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Person}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:can_stay_in ;
        rr:objectMap [ rr:template "http://example.com/main_office/{Place}" ]
    ] .

