# === submit_until (SR) ===
<#submit_untilMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Document\" , \"Deadline\" FROM \"submit_until\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{Document}" ] ;
    rr:predicateObjectMap [
