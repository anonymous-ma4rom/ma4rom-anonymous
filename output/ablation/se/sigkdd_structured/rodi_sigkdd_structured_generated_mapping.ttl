    rr:subjectMap [ rr:template "http://example.com/person/{Author}" ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddstructured:notification_until ;
        rr:objectMap [ rr:template "http://example.com/deadline_abstract_submiss/{Deadline_Author_notificat}" ]
    ] .

