@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix cmtdenormalized: <http://cmt#> .
@base <http://example.com/> .

# === Author (SH) ===
<#AuthorMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"TYPE\" FROM \"Author\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized:Author ] .

# === ProgramCommitteeChair (SH) ===
<#ProgramCommitteeChairMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"ProgramCommitteeChair\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized:ProgramCommitteeChair ] .

# === ProgramCommitteeMember (SH) ===
<#ProgramCommitteeMemberMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"maxPapers\" , \"addedBy\" FROM \"ProgramCommitteeMember\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized:ProgramCommitteeMember ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:maxPapers ;
        rr:objectMap [ rr:column "maxPapers" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:addedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{addedBy}" ]
    ] .

# === User (SH) ===
<#UserMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"acceptPaper\" , \"TYPE\" FROM \"User\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ; rr:class cmtdenormalized:User ] .

# === co-writePaper (SR) ===
<#co-writePaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Co-author\" , \"Paper\" FROM \"co-writePaper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Co-author}" ] ;
    rr:predicateObjectMap [
        rr:predicate <http://cmt#co-writePaper> ;
        rr:objectMap [ rr:template "http://example.com/document/{Paper}" ]
    ] .

# === detailsEnteredBy (SR) ===
<#detailsEnteredByMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Conference\" FROM \"detailsEnteredBy\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:enterConferenceDetails ;
        rr:objectMap [ rr:template "http://example.com/conference/{Conference}" ]
    ] .

# === enableVirtualMeeting (SR) ===
<#enableVirtualMeetingMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Conference\" FROM \"enableVirtualMeeting\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:enableVirtualMeeting ;
        rr:objectMap [ rr:template "http://example.com/conference/{Conference}" ]
    ] .

# === endReview (SR) ===
<#endReviewMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ProgramCommitteeChair\" , \"Review\" FROM \"endReview\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ProgramCommitteeChair}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasConflictOfInterest ;
        rr:objectMap [ rr:template "http://example.com/document/{Review}" ]
    ] .

# === enterReviewCriteria (SR) ===
<#enterReviewCriteriaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Conference\" FROM \"enterReviewCriteria\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:enterReviewCriteria ;
        rr:objectMap [ rr:template "http://example.com/conference/{Conference}" ]
    ] .

# === finalizePaperAssignment (SR) ===
<#finalizePaperAssignmentMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Conference\" FROM \"finalizePaperAssignment\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:finalizePaperAssignment ;
        rr:objectMap [ rr:template "http://example.com/conference/{Conference}" ]
    ] .

# === hardcopyMailingManifestsP (SR) ===
<#hardcopyMailingManifestsPMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference\" , \"Administrator\" FROM \"hardcopyMailingManifestsP\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{Conference}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hardcopyMailingManifestsPrintedBy ;
        rr:objectMap [ rr:template "http://example.com/person/{Administrator}" ]
    ] .

# === hasConferenceMember (SR) ===
<#hasConferenceMemberMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference\" , \"ConferenceMember\" FROM \"hasConferenceMember\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{Conference}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasConferenceMember ;
        rr:objectMap [ rr:template "http://example.com/person/{ConferenceMember}" ]
    ] .

# === hasConflictOfInterest (SR) ===
<#hasConflictOfInterestMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Document\" , \"Person\" FROM \"hasConflictOfInterest\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/document/{Document}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasConflictOfInterest ;
        rr:objectMap [ rr:template "http://example.com/person/{Person}" ]
    ] .

# === hasProgramCommitteeMember (SR) ===
<#hasProgramCommitteeMemberMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ProgramCommittee\" , \"ProgramCommitteeMember\" FROM \"hasProgramCommitteeMember\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/programcommittee/{ProgramCommittee}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:hasProgramCommitteeMember ;
        rr:objectMap [ rr:template "http://example.com/person/{ProgramCommitteeMember}" ]
    ] .

# === paperAssignmentToolsRunBy (SR) ===
<#paperAssignmentToolsRunByMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Conference\" , \"Administrator\" FROM \"paperAssignmentToolsRunBy\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{Conference}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:paperAssignmentToolsRunBy ;
        rr:objectMap [ rr:template "http://example.com/person/{Administrator}" ]
    ] .

# === reviewerBiddingStartedBy (SR) ===
<#reviewerBiddingStartedByMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Conference\" FROM \"reviewerBiddingStartedBy\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:startReviewerBidding ;
        rr:objectMap [ rr:template "http://example.com/conference/{Conference}" ]
    ] .

# === assignReviewer (MV) ===
<#assignReviewerMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"Reviewer\" FROM \"assignReviewer\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:assignReviewer ;
        rr:objectMap [ rr:template "http://example.com/person/{Reviewer}" ]
    ] .

# === hasSubjectArea (MV) ===
# SKIP: hasSubjectArea (MV/OP) 无法解析 range 表

# === setMaxPapers (MV) ===
<#setMaxPapersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Administrator\" , \"ProgramCommitteeMember\" FROM \"setMaxPapers\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Administrator}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:setMaxPapers ;
        rr:objectMap [ rr:template "http://example.com/person/{ProgramCommitteeMember}" ]
    ] .

# === submitPaper (MV) ===
<#submitPaperMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"Author\" , \"Paper\" FROM \"submitPaper\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{Author}" ] ;
    rr:predicateObjectMap [
        rr:predicate cmtdenormalized:submitPaper ;
        rr:objectMap [ rr:template "http://example.com/person/{Paper}" ]
    ] .

# === Author (Type Assertions) ===
<#Author_TYPE_2_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Author\" WHERE \"TYPE\" = 2" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant <http://cmt#Co-author> ]
    ] .

<#Author_TYPE_0_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"Author\" WHERE \"TYPE\" = 0" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtdenormalized:AuthorNotReviewer ]
    ] .

# === User (Type Assertions) ===
<#User_TYPE_0_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" FROM \"User\" WHERE \"TYPE\" = 0" ] ;
    rr:subjectMap [ rr:template "http://example.com/person/{ID}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant cmtdenormalized:Author ]
    ] .
