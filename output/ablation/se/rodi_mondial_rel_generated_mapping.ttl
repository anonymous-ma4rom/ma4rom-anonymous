    ] .

# === mergeswith (SR) ===
<#mergeswithMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"sea1\" , \"sea2\" FROM \"mergeswith\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/sea/{sea1}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:mergesWith ;
