    ] .

# === geo_source (SR) ===
<#geo_sourceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"river\" , \"country\" FROM \"geo_source\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/river/{river}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasSource ;
        rr:objectMap [ rr:template "http://example.com/province/{country}" ]
    ] .

# === locatedon (SR) ===
<#locatedonMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"city\" , \"country\" FROM \"locatedon\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/city/{city}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:locatedAt ;
