    ] .

# === geo_sea (SR) ===
<#geo_seaMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"sea\" , \"country\" FROM \"geo_sea\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/sea/{sea}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel:hasProvince ;
