# === conference_volumes (SH) ===
<#conference_volumesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"program_committee\" , \"organizing_committ\" , \"location\" , \"steering_committee\" , \"important_dates\" FROM \"conference_volumes\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conferences/{id}" ; rr:class conferencerenamed:Conference_volume ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_program_committee ;
        rr:objectMap [ rr:template "http://example.com/committees/{program_committee}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_an_organizing_committee ;
        rr:objectMap [ rr:template "http://example.com/committees/{organizing_committ}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_location ;
        rr:objectMap [ rr:column "location" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_a_steering_committee ;
        rr:objectMap [ rr:template "http://example.com/committees/{steering_committee}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:has_important_dates ;
        rr:objectMap [ rr:template "http://example.com/important_dates/{important_dates}" ]
    ] .

