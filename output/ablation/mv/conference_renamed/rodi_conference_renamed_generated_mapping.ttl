@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix conferencerenamed: <http://conference#> .
@base <http://example.com/> .

# === abstracts (SH) ===
<#abstractsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"th_part\" FROM \"abstracts\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_documents/{id}" ; rr:class conferencerenamed:Abstract ] ;
    rr:predicateObjectMap [
        rr:predicate conferencerenamed:is_the_1th_part_of ;
        rr:objectMap [ rr:template "http://example.com/conference_documents/{th_part}" ]
    ] .

# === accepted_contributions (SH) ===
<#accepted_contributionsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"accepted_contributions\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_documents/{id}" ; rr:class conferencerenamed:Accepted_contribution ] .

