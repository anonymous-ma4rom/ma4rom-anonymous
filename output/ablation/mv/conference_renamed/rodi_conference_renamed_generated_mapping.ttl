# === conferences (SE) ===
<#conferencesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"name\" FROM \"conferences\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conferences/{id}" ; rr:class conferencerenamed:Conference ] ;
    rr:predicateObjectMap [
