# === Important_dates (SE) ===
<#Important_datesMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"is_a_date_of_acceptance_a\" , \"is_a_full_paper_submissio\" , \"is_a_date_of_camera_ready\" , \"is_an_ending_date\" , \"is_a_starting_date\" , \"is_an_abstract_submission\" FROM \"Important_dates\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/important_dates/{ID}" ; rr:class conferencenofks:Important_dates ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenofks:is_a_date_of_acceptance_announcement ;
        rr:objectMap [ rr:column "is_a_date_of_acceptance_a" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenofks:is_a_full_paper_submission_date ;
        rr:objectMap [ rr:column "is_a_full_paper_submissio" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenofks:is_a_date_of_camera_ready_paper_submission ;
        rr:objectMap [ rr:column "is_a_date_of_camera_ready" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencenofks:is_an_ending_date ;
        rr:objectMap [ rr:column "is_an_ending_date" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
