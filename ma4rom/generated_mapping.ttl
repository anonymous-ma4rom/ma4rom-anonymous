        rr:objectMap [ rr:column "End_of_conference" ; rr:datatype xsd:date ]
    ] .

<#PlaceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\", \"lat\", \"long\", \"hasStreet\", \"hasPostalCode\" FROM \"Place\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/place/{ID}" ; rr:class sigkdd:Place ] ;
    rr:predicateObjectMap [
        rr:predicate <http://www.w3.org/2003/01/geo/wgs84_pos#lat> ;
        rr:objectMap [ rr:column "lat" ; rr:datatype xsd:float ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate <http://www.w3.org/2003/01/geo/wgs84_pos#long> ;
        rr:objectMap [ rr:column "long" ; rr:datatype xsd:float ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkdd:hasStreet ;
        rr:objectMap [ rr:column "hasStreet" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkdd:hasPostalCode ;
        rr:objectMap [ rr:column "hasPostalCode" ; rr:datatype xsd:integer ]
    ] .

