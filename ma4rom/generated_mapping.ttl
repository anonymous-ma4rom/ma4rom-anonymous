<#ConferenceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\", \"holded_by\", \"Start_of_conference\", \"City_of_conference\", \"Name_of_conference\", \"End_of_conference\" FROM \"Conference\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference/{ID}" ; rr:class sigkdd:Conference ] ;
    rr:predicateObjectMap [
        rr:predicate sigkdd:holded_by ;
        rr:objectMap [ rr:template "http://example.com/acm_sigkdd/{holded_by}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkdd:Start_of_conference ;
        rr:objectMap [ rr:column "Start_of_conference" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkdd:City_of_conference ;
        rr:objectMap [ rr:column "City_of_conference" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
