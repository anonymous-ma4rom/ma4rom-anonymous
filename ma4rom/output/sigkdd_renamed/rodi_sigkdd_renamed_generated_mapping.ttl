<#author_paper_studentsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"author_paper_students\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ; rr:class sigkddrenamed:Author_of_paper_student ] .

