# === reviews (SH) ===
<#reviewsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" , \"ref\" , \"review\" , \"internal_id\" , \"text\" FROM \"reviews\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/documents/{id}" ; rr:class sigkddrenamed:Review ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddrenamed:isReviewOf ;
        rr:objectMap [ rr:template "http://example.com/documents/{ref}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddrenamed:isReviewOf ;
        rr:objectMap [ rr:template "http://example.com/documents/{review}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddrenamed:hasID ;
        rr:objectMap [ rr:column "internal_id" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddrenamed:hasid ;
        rr:objectMap [ rr:column "internal_id" ; rr:datatype xsd:int ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate sigkddrenamed:hasText ;
        rr:objectMap [ rr:column "text" ; rr:datatype xsd:string ]
    ] .

