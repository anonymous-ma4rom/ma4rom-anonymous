@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix conferencestructured-100: <http://conference#> .
@base <http://example.com/> .

# === Abstract (SH) ===
<#AbstractMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"ID\" , \"is_the_1th_part_of\" , \"has_text\" , \"is_submitted_at\" FROM \"Abstract\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/conference_document/{ID}" ; rr:class conferencestructured-100:Abstract ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured-100:is_the_1th_part_of ;
        rr:objectMap [ rr:template "http://example.com/conference_document/{is_the_1th_part_of}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured-100:has_text ;
        rr:objectMap [ rr:column "has_text" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate conferencestructured-100:is_submitted_at ;
        rr:objectMap [ rr:template "http://example.com/conference_volume/{is_submitted_at}" ]
    ] .

# === Organizing_committee (SH) ===
<#Organizing_committeeMapping> a rr:TriplesMap ;
