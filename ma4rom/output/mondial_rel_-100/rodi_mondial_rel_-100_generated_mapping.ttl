@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix mondialrel-100: <http://www.semwebtech.org/mondial/10/meta#> .
@base <http://example.com/> .

# === economy (SH) ===
<#economyMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"gdp\" , \"agriculture\" , \"service\" , \"industry\" , \"inflation\" , \"unemployment\" FROM \"economy\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/country/{country}" ; rr:class mondialrel-100:Country ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:gdpTotal ;
        rr:objectMap [ rr:column "gdp" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:gdpAgri ;
        rr:objectMap [ rr:column "agriculture" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:gdpServ ;
        rr:objectMap [ rr:column "service" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:gdpInd ;
        rr:objectMap [ rr:column "industry" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:inflation ;
        rr:objectMap [ rr:column "inflation" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:unemployment ;
        rr:objectMap [ rr:column "unemployment" ; rr:datatype xsd:decimal ]
    ] .

# === politics (SH) ===
<#politicsMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"independence\" , \"wasdependent\" , \"dependent\" , \"government\" FROM \"politics\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/country/{country}" ; rr:class mondialrel-100:PoliticalBody ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:independenceDate ;
        rr:objectMap [ rr:column "independence" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:dependentOf ;
        rr:objectMap [ rr:template "http://example.com/country/{dependent}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:government ;
        rr:objectMap [ rr:column "government" ; rr:datatype xsd:string ]
    ] .

# === population (SH) ===
<#populationMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country\" , \"population_growth\" , \"infant_mortality\" FROM \"population\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/country/{country}" ; rr:class mondialrel-100:PopulationCount ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:populationGrowth ;
        rr:objectMap [ rr:column "population_growth" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:infantMortality ;
        rr:objectMap [ rr:column "infant_mortality" ; rr:datatype xsd:decimal ]
    ] .

# === mergeswith (SR) ===
<#mergeswithMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"sea1\" , \"sea2\" FROM \"mergeswith\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/sea/{sea1}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:mergesWith ;
        rr:objectMap [ rr:template "http://example.com/sea/{sea2}" ]
    ] .

# === mountainonisland (SR) ===
<#mountainonislandMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"mountain\" , \"island\" FROM \"mountainonisland\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/mountain/{mountain}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:locatedOnIsland ;
        rr:objectMap [ rr:template "http://example.com/island/{island}" ]
    ] .

# === riverthrough (SR) ===
<#riverthroughMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"river\" , \"lake\" FROM \"riverthrough\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/river/{river}" ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:flowsThrough ;
        rr:objectMap [ rr:template "http://example.com/lake/{lake}" ]
    ] .

# === airport (SE) ===
<#airportMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"iatacode\" , \"name\" , \"country\" , \"city\" , \"province\" , \"island\" , \"latitude\" , \"longitude\" , \"elevation\" , \"gmtoffset\" FROM \"airport\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/airport/{iatacode}" ; rr:class mondialrel-100:Location ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:cityIn ;
        rr:objectMap [ rr:template "http://example.com/country/{country}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:isCapitalOf ;
        rr:objectMap [ rr:template "http://example.com/island/{island}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:latitude ;
        rr:objectMap [ rr:column "latitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:longitude ;
        rr:objectMap [ rr:column "longitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:elevation ;
        rr:objectMap [ rr:column "elevation" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:longitude ;
        rr:objectMap [ rr:column "gmtoffset" ; rr:datatype xsd:decimal ]
    ] .

# === borders (SE) ===
<#bordersMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"country1\" , \"country2\" , \"length\" FROM \"borders\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/borders/{country1}__{country2}" ; rr:class mondialrel-100:Border ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:length ;
        rr:objectMap [ rr:column "length" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:bordering ;
        rr:objectMap [ rr:template "http://example.com/country/{country1}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:bordering ;
        rr:objectMap [ rr:template "http://example.com/country/{country2}" ]
    ] .

# === city (SE) ===
<#cityMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"country\" , \"province\" , \"population\" , \"latitude\" , \"longitude\" , \"elevation\" FROM \"city\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/city/{name}__{country}__{province}" ; rr:class mondialrel-100:City ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:population ;
        rr:objectMap [ rr:column "population" ; rr:datatype xsd:nonNegativeInteger ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:latitude ;
        rr:objectMap [ rr:column "latitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:longitude ;
        rr:objectMap [ rr:column "longitude" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:elevation ;
        rr:objectMap [ rr:column "elevation" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:cityIn ;
        rr:objectMap [ rr:template "http://example.com/country/{country}" ]
    ] .

# === cityothername (SE) ===
<#cityothernameMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"city\" , \"country\" , \"province\" , \"othername\" FROM \"cityothername\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/cityothername/{country}__{province}__{city}__{othername}" ; rr:class mondialrel-100:City ] ;
    rr:predicateObjectMap [
