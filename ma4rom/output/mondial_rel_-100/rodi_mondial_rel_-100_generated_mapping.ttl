    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"river\" , \"lake\" , \"sea\" , \"length\" , \"source\" , \"mountains\" , \"sourceelevation\" , \"estuary\" FROM \"river\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/river/{name}" ; rr:class mondialrel-100:River ] ;
