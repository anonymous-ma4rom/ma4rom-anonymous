# === locatedon (SE) ===
<#locatedonMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"city\" , \"province\" , \"country\" , \"island\" FROM \"locatedon\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/locatedon/{city}__{province}__{country}__{island}" ; rr:class mondialrel-100:Location ] .

# === mountain (SE) ===
<#mountainMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"mountains\" , \"elevation\" , \"type\" , \"coordinates\" FROM \"mountain\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/mountain/{name}" ; rr:class mondialrel-100:Mountain ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:elevation ;
        rr:objectMap [ rr:column "elevation" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] .

# === organization (SE) ===
<#organizationMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"abbreviation\" , \"name\" , \"city\" , \"country\" , \"province\" , \"established\" FROM \"organization\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/organization/{abbreviation}" ; rr:class mondialrel-100:Organization ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:cityIn ;
        rr:objectMap [ rr:template "http://example.com/country/{country}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:abbrev ;
        rr:objectMap [ rr:column "province" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:established ;
        rr:objectMap [ rr:column "established" ; rr:datatype xsd:date ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:abbrev ;
        rr:objectMap [ rr:column "abbreviation" ; rr:datatype xsd:string ]
    ] .

# === province (SE) ===
<#provinceMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"name\" , \"country\" , \"population\" , \"area\" , \"capital\" , \"capprov\" FROM \"province\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/province/{name}__{country}" ; rr:class mondialrel-100:Province ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:population ;
        rr:objectMap [ rr:column "population" ; rr:datatype xsd:nonNegativeInteger ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:area ;
        rr:objectMap [ rr:column "area" ; rr:datatype xsd:decimal ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:name ;
        rr:objectMap [ rr:column "name" ; rr:datatype xsd:string ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:cityIn ;
        rr:objectMap [ rr:template "http://example.com/country/{country}" ]
    ] .

