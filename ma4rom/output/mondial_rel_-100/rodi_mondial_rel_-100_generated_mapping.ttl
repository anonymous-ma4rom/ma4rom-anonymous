    ] .

# === geo_mountain (SE) ===
<#geo_mountainMapping> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"mountain\" , \"country\" , \"province\" FROM \"geo_mountain\"" ] ;
    rr:subjectMap [ rr:template "http://example.com/geo_mountain/{province}__{country}__{mountain}" ; rr:class mondialrel-100:Mountain ] .

# === geo_river (SE) ===
