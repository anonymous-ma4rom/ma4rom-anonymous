        rr:objectMap [ rr:template "http://example.com/country/{country}" ]
    ] ;
    rr:predicateObjectMap [
        rr:predicate mondialrel-100:othername ;
        rr:objectMap [ rr:column "othername" ; rr:datatype xsd:string ]
    ] .

