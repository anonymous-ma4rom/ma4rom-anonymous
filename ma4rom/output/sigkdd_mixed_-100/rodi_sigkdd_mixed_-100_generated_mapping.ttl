    ] .

<#persons_author_paper_student_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"author_paper_student\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
