    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"listener\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
