    ] .

# === registration_fees (Type Assertions) ===
<#registration_fees_type_0_Registration_fee_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"registration_fees\" WHERE \"type\" = 0" ] ;
    rr:subjectMap [ rr:template "http://example.com/registration_fees/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddmixed-100:Registration_fee ]
    ] .
