<#persons_program_committee_member_true_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"program_committee_member\" = true" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
        rr:predicate rdf:type ;
        rr:objectMap [ rr:constant sigkddmixed-100:Program_Committee_member ]
    ] .

<#persons_type_2_Author_Type> a rr:TriplesMap ;
    rr:logicalTable [ rr:sqlQuery "SELECT \"id\" FROM \"persons\" WHERE \"type\" = 2" ] ;
    rr:subjectMap [ rr:template "http://example.com/persons/{id}" ] ;
    rr:predicateObjectMap [
